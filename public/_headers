# Security headers on every response. HSTS has no `preload` token (avoids the
# preload-list commitment); CSP keeps 'unsafe-inline' so hydration/inline JSON-LD
# keep working — tighten to nonces/hashes as a follow-up.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cache-Control: public, max-age=0, must-revalidate
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://connect.facebook.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com https://www.facebook.com https://*.facebook.com; font-src 'self'; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://connect.facebook.net; frame-src https://www.google.com https://www.googletagmanager.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests

# Content-hashed bundles — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Stable media — 30 days.
/assets/*
  Cache-Control: public, max-age=2592000
/brand/*
  Cache-Control: public, max-age=2592000
