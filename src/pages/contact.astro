---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WhatsAppLink from '../components/WhatsAppLink.astro';
import CTAButton from '../components/CTAButton.astro';
import { SITE } from '../consts';

const title = 'Contact — Ivory Arc Travels';
const description =
  'Talk to Ivory Arc about a private journey across North India. Reach IVY on WhatsApp for fast planning, call us, or email — we’re based in Agra and reply within about two hours.';

const mapsQuery = encodeURIComponent(
  `${SITE.addressLine}, ${SITE.city} ${SITE.postcode}, ${SITE.region}, ${SITE.country}`,
);
const mapsSrc = `https://www.google.com/maps?q=${mapsQuery}&output=embed`;
---

<BaseLayout title={title} description={description} canonical="/contact">
  <section class="container-ed py-16 md:py-24">
    <SectionHeading
      eyebrow="Contact"
      title="Three easy ways to reach us."
      intro="The fastest way to reach us is on WhatsApp — IVY can start shaping an itinerary and an indicative price straight away. Prefer to call or email? We’re here for that too."
      align="left"
    />
    <p class="mt-3 text-sm text-muted">Replies within about two hours · No booking fees · No obligation</p>

    <div class="mt-12 grid gap-10 md:grid-cols-[1.2fr_1fr] md:gap-16">
      <div class="space-y-8">
        <div>
          <h2 class="text-h3">Chat with IVY on WhatsApp</h2>
          <p class="mt-2 max-w-md text-muted">
            Planning, availability and an honest indicative quote — the quickest path to a journey.
          </p>
          <div class="mt-4"><WhatsAppLink agent="ivy" variant="primary" location="contact" /></div>
        </div>

        <div>
          <h2 class="text-h3">Call us</h2>
          <p class="mt-2 max-w-md text-muted">
            Speak to the team directly — ideal for complex, multi-region or special-occasion journeys.
          </p>
          <p class="mt-3">
            <a class="font-display text-2xl text-teal underline underline-offset-4" href={`tel:${SITE.phoneTel}`}>{SITE.phoneDisplay}</a>
          </p>
          <div class="mt-3"><WhatsAppLink agent="specialist" variant="secondary" location="contact" /></div>
        </div>

        <div>
          <h2 class="text-h3">Email</h2>
          <p class="mt-2 max-w-md text-muted">For detailed enquiries, quotes and anything you’d like in writing.</p>
          <p class="mt-3">
            <a class="text-teal underline underline-offset-2" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </p>
        </div>

        <div>
          <h2 class="text-h3">Prefer to start online?</h2>
          <p class="mt-2 max-w-md text-muted">
            Use the estimator to shape a journey and see an indicative range in INR before you talk to anyone.
          </p>
          <div class="mt-4">
            <CTAButton href="/plan" variant="secondary" label="Open the estimator" target="estimator" location="contact" />
          </div>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-line bg-cream p-6">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Where we are</h2>
          <address class="mt-4 not-italic text-sm leading-relaxed text-ink">
            {SITE.name}<br />
            {SITE.addressLine}<br />
            {SITE.city} {SITE.postcode}<br />
            {SITE.region}, {SITE.country}
          </address>
          <p class="mt-4 text-sm text-muted">
            By appointment, open every day. We typically reply within about two hours.
          </p>
          <dl class="mt-4 space-y-3 border-t border-line pt-4 text-sm">
            <div><dt class="text-muted">GST</dt><dd class="text-ink">{SITE.gst}</dd></div>
            <div><dt class="text-muted">Registration</dt><dd class="text-ink">Registered Indian tour operator · {SITE.msme}</dd></div>
            <div><dt class="text-muted">Billing</dt><dd class="text-ink">All journeys billed in INR — other currencies indicative only</dd></div>
          </dl>
        </div>

        <div class="overflow-hidden rounded-lg border border-line">
          <iframe
            src={mapsSrc}
            width="100%"
            height="320"
            style="border:0;display:block"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`${SITE.name} — ${SITE.city}`}
          ></iframe>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
