---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import WhatsAppLink from '../components/WhatsAppLink.astro';
import { SITE } from '../consts';

const title = 'About — Ivory Arc Travels';
const description =
  'Ivory Arc Travels is a women-owned, family-run private travel company founded in 2019 by Sonu Tomar — built on firsthand knowledge of every road, temple and city across North India.';

const promises = [
  { t: 'No commission stops', d: 'Never any commission-driven shopping detours — your time on the road is spent on what you came for.' },
  { t: 'All of North India', d: 'From Agra and the Taj to the Golden Temple, the Ganges and the Himalaya — one team across the whole region.' },
  { t: 'Private, always', d: 'Your own vehicle, guide and pace — never a fixed group departure or a shared coach.' },
];
---

<BaseLayout title={title} description={description} canonical="/about">
  <section class="container-ed py-16 md:py-24">
    <SectionHeading
      eyebrow="About"
      title="Founded on experience, run with care."
      intro="Ivory Arc Travels is a women-owned, family-run private travel company — built on firsthand knowledge of every road, temple and city we send you to. Honest. Unhurried. Yours."
      align="left"
    />

    <div class="mt-10 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <div>
        <h2 class="text-h3">Our story</h2>
        <div class="mt-4 space-y-5 text-lg text-muted">
          <p>
            Ivory Arc Travels was founded in 2019 by <strong class="text-ink">Sonu Tomar</strong>, a
            passionate traveller who believes exceptional journeys are built on personal experience,
            meticulous planning and genuine care for every guest. What began as a family-led venture
            now combines decades of expertise from across the travel ecosystem.
          </p>
          <p>
            Sonu's father, an <strong class="text-ink">Army veteran</strong>, has been involved in
            travel operations since 2016 — bringing discipline, reliability and a service-first
            approach to every itinerary. Her husband contributes over a decade of experience with
            leading travel management companies, online travel agencies, airlines and hospitality
            brands, adding deep industry insight and operational excellence.
          </p>
          <p>
            What truly sets us apart is <strong class="text-ink">firsthand destination knowledge</strong>.
            Sonu has personally visited every destination in our curated journeys — many of them
            several times over. That lets us move beyond generic sightseeing to craft experiences that
            are practical, authentic and thoughtfully designed: every route, stay, activity and local
            experience chosen from real-world experience, not online research alone.
          </p>
        </div>
      </div>

      <aside class="rounded-lg border border-line bg-cream p-6 lg:self-start">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">At a glance</h2>
        <dl class="mt-4 space-y-3 text-sm">
          <div><dt class="text-muted">Founded</dt><dd class="text-ink">2019, by Sonu Tomar — women-owned &amp; family-run</dd></div>
          <div><dt class="text-muted">Where we’re based</dt><dd class="text-ink">{SITE.city}, {SITE.region}</dd></div>
          <div><dt class="text-muted">Where we travel</dt><dd class="text-ink">{SITE.destinationCount} destinations across North India</dd></div>
          <div><dt class="text-muted">How we travel</dt><dd class="text-ink">Private journeys only — your own vehicle, driver and guides</dd></div>
          <div><dt class="text-muted">Registration</dt><dd class="text-ink">Registered Indian tour operator · GST {SITE.gst} · {SITE.msme}</dd></div>
        </dl>
      </aside>
    </div>

    <div class="mt-16">
      <h2 class="text-h3">Enriching, stress-free, transparent.</h2>
      <div class="mt-4 max-w-3xl space-y-5 text-lg text-muted">
        <p>
          We specialise in private, thoughtfully curated experiences that prioritise quality over
          volume. Rather than selling standard packages, we start by understanding your interests,
          travel style and expectations — then build a journey that feels personal and meaningful.
          Whether you're a solo traveller, a couple, a family or a small private group, we plan around
          secure stays, trusted local partners, realistic pacing and seamless logistics.
        </p>
        <p>
          Our philosophy is simple: travel should be enriching, stress-free and transparent. It's why
          we hold ourselves to three promises on every trip.
        </p>
      </div>

      <dl class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          promises.map((p) => (
            <div class="rounded-lg border-l-2 border-gold bg-cream px-5 py-4">
              <dt class="font-display text-lg text-ink">{p.t}</dt>
              <dd class="mt-1 text-sm text-muted">{p.d}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="mt-14 flex flex-col items-start gap-3 sm:flex-row">
      <WhatsAppLink variant="primary" location="about_footer" />
      <CTAButton href="/plan" variant="secondary" label="Get an estimate" target="estimator" location="about_footer" />
    </div>
  </section>
</BaseLayout>
