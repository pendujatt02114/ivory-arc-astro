---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import WhatsAppLink from '../components/WhatsAppLink.astro';
import CTAButton from '../components/CTAButton.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE } from '../consts';

const title = 'FAQ — Ivory Arc Travels';
const description =
  'Common questions about pricing, payments, customization, regions and how planning with Ivory Arc works.';

const faqs = [
  { q: 'How does your pricing work?', a: 'Every journey is priced transparently: hotels and ground services at actual cost, plus a single, clearly stated 10% coordination fee. There are no fixed packages and no markups buried in the price.' },
  { q: 'Are your prices fixed packages?', a: 'No. Each itinerary is built from scratch around your interests, pace and dates. The estimator gives an indicative range; your exact quote is confirmed with IVY once the journey is shaped.' },
  { q: 'What currency am I billed in?', a: 'All journeys are billed in Indian Rupees (INR). The USD, EUR and GBP figures shown on the site are indicative conversions only.' },
  { q: 'How do I pay, and is it secure?', a: 'Payments are handled through Razorpay, which supports major cards and UPI. Journeys are typically confirmed with an advance, with the balance due before travel.' },
  { q: 'Is GST included?', a: `Indian Goods and Services Tax is applied as required by law and shown on your invoice. Our GST registration is ${SITE.gst}.` },
  { q: 'Do you run group tours?', a: 'No — Ivory Arc designs private journeys only. No shared coaches and no fixed departures. Your guide, vehicle and schedule are yours alone.' },
  { q: 'Will I be taken to shops for commission?', a: 'Never. We do not route journeys through emporiums or workshops for kickbacks. Your time on the road is spent on what you came to see.' },
  { q: 'Who actually plans my trip — AI or people?', a: 'IVY, our planning concierge, shapes a first itinerary and indicative price quickly. For complex or multi-region journeys, our human specialists take over with local judgement.' },
  { q: 'Which regions do you cover?', a: 'North India: Delhi NCR, Rajasthan, Uttar Pradesh, Uttarakhand, Punjab, Himachal Pradesh and Jammu.' },
  { q: 'Can you guide in languages other than English?', a: 'Yes. We support enquiries in English, Spanish, German and French, and can arrange private guides by language on request.' },
  { q: 'How do I get started?', a: 'Open the estimator to shape a journey and see an indicative range, or message IVY on WhatsApp and we’ll take it from there.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} canonical="/faq">
  <section class="container-ed py-16 md:py-24">
    <SectionHeading as="h1" eyebrow="FAQ" title="Questions, answered." align="left" />

    <div class="mt-10 max-w-3xl divide-y divide-line border-y border-line">
      {
        faqs.map((f) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-h3 [&::-webkit-details-marker]:hidden">
              <span>{f.q}</span>
              <svg
                class="size-5 shrink-0 text-teal transition-transform group-open:rotate-45"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path d="M12 5v14M5 12h14" stroke-linecap="round" />
              </svg>
            </summary>
            <p class="mt-3 max-w-2xl text-muted">{f.a}</p>
          </details>
        ))
      }
    </div>

    <div class="mt-12 flex flex-col items-start gap-3 sm:flex-row">
      <WhatsAppLink variant="primary" location="faq_footer" />
      <CTAButton href="/plan" variant="secondary" label="Get an estimate" target="estimator" location="faq_footer" />
    </div>
  </section>

  <JsonLd schema={faqSchema} />
</BaseLayout>
