---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../consts';
import type { Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  const locales = ['es', 'de', 'fr', 'it', 'ru'];
  const docs = ["privacy", "terms", "refund-cancellation"];
  return locales.flatMap((locale) => docs.map((doc) => ({ params: { locale, doc } })));
}

const { locale, doc } = Astro.params;
const lang = locale as Lang;
const DOCNAME: Record<string, Record<string, string>> = {"privacy": {"en": "Privacy Policy", "es": "Política de Privacidad", "de": "Datenschutzerklärung", "fr": "Politique de confidentialité", "it": "Informativa sulla privacy", "ru": "Политика конфиденциальности"}, "terms": {"en": "Terms & Conditions", "es": "Términos y Condiciones", "de": "Allgemeine Geschäftsbedingungen", "fr": "Conditions générales", "it": "Termini e condizioni", "ru": "Условия использования"}, "refund-cancellation": {"en": "Refund & Cancellation Policy", "es": "Política de Reembolsos y Cancelaciones", "de": "Erstattungs- & Stornierungsrichtlinie", "fr": "Politique de remboursement et d’annulation", "it": "Politica di rimborso e cancellazione", "ru": "Политика возврата и отмены"}};
const CH: Record<string, any> = {"en": {"eyebrow": "Legal", "notice": "For legal precision, our policies are maintained in English, which is the governing version. Please read the full policy in English using the link below.", "btn": "Read the full policy in English", "reg": "Registered Indian tour operator"}, "es": {"eyebrow": "Legal", "notice": "Por precisión jurídica, nuestras políticas se mantienen en inglés, que es la versión vinculante. Lee la política completa en inglés con el enlace de abajo.", "btn": "Leer la política completa en inglés", "reg": "Operador turístico indio registrado"}, "de": {"eyebrow": "Rechtliches", "notice": "Aus Gründen der rechtlichen Genauigkeit werden unsere Richtlinien auf Englisch geführt, das die maßgebliche Fassung ist. Bitte lesen Sie die vollständige Richtlinie auf Englisch über den untenstehenden Link.", "btn": "Vollständige Richtlinie auf Englisch lesen", "reg": "Registrierter indischer Reiseveranstalter"}, "fr": {"eyebrow": "Mentions légales", "notice": "Pour des raisons de précision juridique, nos politiques sont tenues en anglais, qui est la version faisant foi. Veuillez lire la politique complète en anglais via le lien ci-dessous.", "btn": "Lire la politique complète en anglais", "reg": "Voyagiste indien agréé"}, "it": {"eyebrow": "Note legali", "notice": "Per precisione giuridica, le nostre politiche sono mantenute in inglese, che è la versione prevalente. Leggi la politica completa in inglese tramite il link qui sotto.", "btn": "Leggi la politica completa in inglese", "reg": "Tour operator indiano registrato"}, "ru": {"eyebrow": "Правовая информация", "notice": "Для юридической точности наши политики ведутся на английском языке, который является имеющей силу версией. Пожалуйста, прочитайте полную политику на английском по ссылке ниже.", "btn": "Читать полную политику на английском", "reg": "Зарегистрированный индийский туроператор"}};
const c = CH[lang] ?? CH.en;
const name = (DOCNAME[doc as string]?.[lang]) ?? DOCNAME[doc as string]?.en ?? '';
const enHref = `/legal/${doc}`;
const canonical = `/${lang}/legal/${doc}`;
---
<BaseLayout title={`${name} — Ivory Arc Travels`} description={c.notice} lang={lang} canonical={canonical} hreflangPath={`/legal/${doc}`} noBar={true}>
  <section class="container-ed py-16 md:py-24">
    <p class="text-xs font-medium uppercase tracking-[0.24em] text-teal-700">{c.eyebrow}</p>
    <h1 class="mt-4 text-display">{name}</h1>
    <div class="mt-6 max-w-2xl rounded-lg border border-line bg-cream p-6">
      <p class="text-muted">{c.notice}</p>
      <a href={enHref} class="mt-5 inline-flex min-h-[44px] items-center justify-center rounded-lg bg-gold px-5 font-semibold text-ink transition hover:bg-gold-600">{c.btn} →</a>
    </div>
    <p class="mt-6 text-sm text-muted">{c.reg} · GST {SITE.gst} · {SITE.msme}</p>
  </section>
</BaseLayout>
