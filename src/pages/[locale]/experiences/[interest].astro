---
import ExperiencesBody from '../../../components/pages/ExperiencesBody.astro';
import type { Lang } from '../../../i18n/ui';
export function getStaticPaths() {
  const locales = ['es', 'de', 'fr', 'it', 'ru'];
  const interests = ['heritage', 'spiritual', 'pilgrimage', 'mountains', 'wildlife', 'luxury'];
  return locales.flatMap((locale) => interests.map((interest) => ({ params: { locale, interest } })));
}
const { locale, interest } = Astro.params;
---
<ExperiencesBody lang={locale as Lang} interest={interest as string} />
