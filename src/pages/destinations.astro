---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Picture from '../components/Picture.astro';
import CTAButton from '../components/CTAButton.astro';
import WhatsAppLink from '../components/WhatsAppLink.astro';
import { SITE } from '../consts';

const title = 'Destinations — Ivory Arc Travels';
const description = `Where we travel across North India — ${SITE.destinationCount} destinations and counting, from Agra and the Taj Mahal to Varanasi, the Golden Temple, Rajasthan, the Himalaya and the great pilgrimage routes. Private journeys shaped around you.`;

// `img` = base path to an optimized photo pair (avif/webp). Omit it for places
// we cover but don't yet have a photo for — those render an on-brand arch card
// in the identical layout (drop a photo in and add `img` to swap it in).
type Place = { img?: string; name: string; region: string; note: string };

const places: Place[] = [
  // Marquee cities first — Agra leads (the Taj is the most-visited monument by international travellers).
  { name: 'Agra', region: 'Uttar Pradesh', note: 'The Taj Mahal — the monument the world comes to see, plus Agra Fort and Fatehpur Sikri.' },
  { name: 'Jaipur', region: 'Rajasthan', note: 'The Pink City — Amber Fort, Hawa Mahal and royal bazaars; the third point of the Golden Triangle.' },
  { img: '/assets/destinations/varanasi/varanasi-aarti', name: 'Varanasi', region: 'Uttar Pradesh', note: 'The eternal city — dawn boats on the Ganga and the lamp-lit evening aarti.' },
  { name: 'Mathura & Vrindavan', region: 'Uttar Pradesh', note: "Krishna's birthplace — twin temple towns of devotion on the Yamuna." },
  { name: 'Haridwar & Rishikesh', region: 'Uttarakhand', note: 'Where the Ganga leaves the mountains — the Ganga aarti, ashrams and the yoga capital of the world.' },
  { name: 'Amritsar', region: 'Punjab', note: "The Golden Temple — Sikhism's holiest shrine, gold on water, and the Wagah border ceremony." },
  // The rest of the network (photographed).
  { img: '/assets/thumbnails/udaipur', name: 'Udaipur', region: 'Rajasthan', note: 'Lake palaces, marble courtyards and sunset boats on Lake Pichola.' },
  { img: '/assets/thumbnails/jodhpur', name: 'Jodhpur', region: 'Rajasthan', note: 'The blue city beneath the ramparts of Mehrangarh Fort.' },
  { img: '/assets/thumbnails/jaisalmer', name: 'Jaisalmer', region: 'Rajasthan', note: 'A living golden-sandstone fort on the edge of the Thar Desert.' },
  { img: '/assets/thumbnails/pushkar', name: 'Pushkar', region: 'Rajasthan', note: 'A sacred lake town of ghats, temples and the famous camel fair.' },
  { img: '/assets/thumbnails/bikaner', name: 'Bikaner', region: 'Rajasthan', note: 'Junagarh Fort, ornate havelis and old Silk Road trade routes.' },
  { img: '/assets/thumbnails/ranthambore', name: 'Ranthambore', region: 'Rajasthan', note: "India's most storied tiger reserve, wrapped around a hilltop fort." },
  { img: '/assets/thumbnails/ayodhya', name: 'Ayodhya', region: 'Uttar Pradesh', note: 'The Ram Mandir and the spiritual heart of the Sarayu riverlands.' },
  { img: '/assets/thumbnails/khajjiar', name: 'Khajjiar', region: 'Himachal Pradesh', note: 'Alpine meadows ringed by deodar forest — the “mini Switzerland”.' },
  { img: '/assets/thumbnails/solang-valley', name: 'Solang Valley', region: 'Himachal Pradesh', note: 'High-altitude adventure and snow above the Manali valley.' },
  { img: '/assets/thumbnails/patiala', name: 'Patiala', region: 'Punjab', note: 'Royal Punjab — Qila Mubarak, gardens and a living court culture.' },
  { img: '/assets/thumbnails/vaishno-devi', name: 'Vaishno Devi', region: 'Jammu', note: "One of India's most revered pilgrimages, in the Trikuta hills." },
];

const reasons = [
  { t: 'The length & breadth of North India', d: `${SITE.destinationCount} destinations and counting — from the Himalaya to the Thar, the Ganga plains to the Sutlej.` },
  { t: 'Every kind of place covered', d: 'Heritage cities, sacred rivers, tiger forests, mountain valleys and the great pilgrimage trails — all on one itinerary if you like.' },
  { t: 'However complex, we’ve got your back', d: 'One team and one point of contact, start to finish — no matter how many cities, transfers or special requests your plan involves.' },
];
---

<BaseLayout title={title} description={description} canonical="/destinations">
  <section class="container-ed py-16 md:py-24">
    <SectionHeading
      eyebrow="Destinations"
      title="Where we travel."
      intro={`We plan private journeys across the length and breadth of North India — ${SITE.destinationCount} destinations in all, from the palaces of Rajasthan to the Ganges, the Himalaya, the tiger forests and the holiest pilgrimage sites. Each place below is a starting point, never a fixed package.`}
      align="left"
    />

    <dl class="mt-8 grid gap-4 sm:grid-cols-3">
      {
        reasons.map((r) => (
          <div class="rounded-lg border-l-2 border-gold bg-cream px-5 py-4">
            <dt class="font-display text-lg text-ink">{r.t}</dt>
            <dd class="mt-1 text-sm text-muted">{r.d}</dd>
          </div>
        ))
      }
    </dl>

    <ul class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-5">
      {
        places.map((p) => (
          <li>
            <a
              href="/plan"
              class="group relative block aspect-[4/5] w-full overflow-hidden rounded-lg"
              data-cta
              data-cta-target="estimator"
              data-cta-location="destinations_grid"
              data-cta-label={p.name}
            >
              {p.img ? (
                <>
                  <Picture
                    base={p.img}
                    alt={`${p.name}, ${p.region}`}
                    width={800}
                    height={1000}
                    sizes="(min-width: 768px) 33vw, 50vw"
                    class="absolute inset-0 block h-full w-full"
                    imgClass="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                  <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-teal-900/85 via-teal-900/20 to-transparent" />
                </>
              ) : (
                <>
                  <span class="absolute inset-0 bg-gradient-to-br from-teal-800 via-teal-900 to-ink" />
                  <svg
                    viewBox="0 0 100 130"
                    class="absolute left-1/2 top-1/2 h-3/5 w-auto -translate-x-1/2 -translate-y-[58%] text-gold/25 transition-transform duration-500 group-hover:scale-105"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    aria-hidden="true"
                  >
                    <path d="M14 126 V58 C14 30 30 12 50 7 C70 12 86 30 86 58 V126" stroke-linecap="round" />
                    <path d="M50 7 V126" opacity="0.45" />
                  </svg>
                  <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-teal-900/70 to-transparent" />
                </>
              )}
              <div class="absolute inset-x-0 bottom-0 p-4">
                <p class="text-[0.7rem] font-medium uppercase tracking-[0.18em] text-gold">{p.region}</p>
                <h2 class="mt-0.5 font-display text-xl !text-ivory">{p.name}</h2>
                <p class="mt-1 text-sm text-ivory/85">{p.note}</p>
              </div>
            </a>
          </li>
        ))
      }

      <li>
        <a
          href="/plan"
          class="group relative flex aspect-[4/5] w-full flex-col items-center justify-center overflow-hidden rounded-lg border border-gold/40 bg-gradient-to-br from-teal-700 via-teal-800 to-ink p-5 text-center"
          data-cta
          data-cta-target="estimator"
          data-cta-location="destinations_grid"
          data-cta-label="Many more"
        >
          <span class="text-[0.7rem] font-medium uppercase tracking-[0.22em] text-gold">And</span>
          <span class="mt-1 font-display text-3xl !text-ivory md:text-4xl">Many more</span>
          <span class="mt-3 text-sm text-gold">{SITE.destinationCount} destinations across North India</span>
          <span class="mt-2 text-xs text-ivory/75">From the Himalaya to the desert — wherever your itinerary leads.</span>
          <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-[0.14em] text-ivory transition-transform duration-300 group-hover:translate-x-0.5">
            Plan your journey →
          </span>
        </a>
      </li>
    </ul>

    <div class="mt-12 flex flex-col items-start gap-3 sm:flex-row">
      <CTAButton href="/plan" variant="primary" label="Get an estimate" target="estimator" location="destinations_footer" />
      <WhatsAppLink variant="secondary" location="destinations_footer" />
    </div>
  </section>
</BaseLayout>
