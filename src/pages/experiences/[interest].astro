---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Picture from '../../components/Picture.astro';
import CTAButton from '../../components/CTAButton.astro';
import WhatsAppLink from '../../components/WhatsAppLink.astro';

// Destination copy — names + one-line summaries, drawn from the regions the estimator covers.
const DEST: Record<string, { name: string; blurb: string }> = {
  golden_triangle: { name: 'Golden Triangle', blurb: 'Delhi, Agra and Jaipur — the classic first arc of North India.' },
  delhi: { name: 'Delhi', blurb: 'Mughal monuments, Lutyens’ avenues and old-city bazaars.' },
  agra: { name: 'Agra', blurb: 'The Taj Mahal at dawn and the riverside Mughal forts.' },
  jaipur: { name: 'Jaipur', blurb: 'The pink city of palaces, forts and living craft.' },
  udaipur: { name: 'Udaipur', blurb: 'Lake palaces and marble courtyards in the Aravalli hills.' },
  jodhpur: { name: 'Jodhpur', blurb: 'The blue city beneath the ramparts of Mehrangarh Fort.' },
  pushkar: { name: 'Pushkar', blurb: 'A sacred lake town of ghats, temples and the camel fair.' },
  varanasi: { name: 'Varanasi', blurb: 'The eternal city on the Ganges, alive at every ghat.' },
  amritsar: { name: 'Amritsar', blurb: 'The Golden Temple and the soul of Punjab.' },
  haridwar: { name: 'Haridwar', blurb: 'Where the Ganges meets the plains — and the evening aarti.' },
  rishikesh: { name: 'Rishikesh', blurb: 'Yoga, the river, and the foothills of the Himalaya.' },
  mathura_vrindavan: { name: 'Mathura & Vrindavan', blurb: 'The birthplace of Krishna and its temple towns.' },
  ayodhya: { name: 'Ayodhya', blurb: 'The Ram Mandir and the Sarayu riverlands.' },
  kainchi_dham: { name: 'Kainchi Dham', blurb: 'A serene Himalayan ashram above Nainital.' },
  vaishno_devi: { name: 'Vaishno Devi', blurb: 'A revered hill pilgrimage in the Trikuta range.' },
  jwala_ji: { name: 'Jwala Ji', blurb: 'The temple of the eternal flame in the Kangra valley.' },
  chintpurni: { name: 'Chintpurni', blurb: 'A cherished Shakti shrine in the Himachal hills.' },
  jim_corbett: { name: 'Jim Corbett', blurb: 'India’s oldest national park, in the Kumaon foothills.' },
  ranthambore: { name: 'Ranthambore', blurb: 'Tiger country wrapped around a hilltop fort.' },
  shimla_manali: { name: 'Shimla & Manali', blurb: 'The classic Himalayan escape — cool air and high passes.' },
  dharamshala: { name: 'Dharamshala & McLeod Ganj', blurb: 'Tibetan culture and pine ridges above the Kangra valley.' },
  dalhousie: { name: 'Dalhousie', blurb: 'Colonial-era hill calm amid deodar forest.' },
  mussoorie: { name: 'Mussoorie', blurb: 'The “queen of the hills” above the Doon valley.' },
  nainital: { name: 'Nainital', blurb: 'A lake town ringed by Kumaon’s wooded hills.' },
  chandigarh: { name: 'Chandigarh', blurb: 'India’s most elegant planned city, gateway to the hills.' },
};

const EXP: Record<
  string,
  { title: string; hero: string; lead: string; dests: string[]; includes: string[] }
> = {
  heritage: {
    title: 'Heritage Journeys',
    hero: '/assets/thumbnails/jodhpur',
    lead: 'Forts, palaces and walled cities — North India’s living history, explored privately with expert guides and never a commission-driven stop.',
    dests: ['golden_triangle', 'delhi', 'agra', 'jaipur', 'udaipur', 'jodhpur', 'pushkar', 'varanasi', 'amritsar'],
    includes: [
      'Private air-conditioned vehicle with a professional chauffeur throughout.',
      'Expert heritage and history guides at each city.',
      'Monument and fort entries arranged (charged at actuals; rates vary by nationality).',
      'Hand-picked heritage and palace stays — hotels at actual cost plus a transparent 10% coordination fee.',
      'Curated artisan and craft encounters, without shopping commissions.',
      '24×7 on-trip support from your Journey Manager.',
    ],
  },
  spiritual: {
    title: 'Spiritual Journeys',
    hero: '/assets/thumbnails/ayodhya',
    lead: 'Sacred rivers, temple towns and the quiet energy of North India’s holiest places — arranged with care and respect for every tradition.',
    dests: ['varanasi', 'haridwar', 'rishikesh', 'mathura_vrindavan', 'ayodhya', 'pushkar', 'amritsar', 'kainchi_dham'],
    includes: [
      'Private vehicle and chauffeur, with comfortable, unhurried pacing.',
      'Temple and ghat visits with knowledgeable local guides.',
      'Evening aarti experiences, including the Ganga aarti where offered.',
      'Respectful darshan coordination and dawn riverside moments.',
      'Thoughtfully located stays — at actual cost plus a transparent 10% coordination fee.',
      '24×7 on-trip support throughout.',
    ],
  },
  pilgrimage: {
    title: 'Pilgrimage Journeys',
    hero: '/assets/thumbnails/vaishno-devi',
    lead: 'The classic yatras and shrines of the north, arranged end to end — with the assistance and pacing that make a pilgrimage restful as well as moving.',
    dests: ['vaishno_devi', 'jwala_ji', 'chintpurni', 'haridwar', 'ayodhya', 'amritsar', 'mathura_vrindavan'],
    includes: [
      'Full yatra coordination — routes, timings and stays planned around darshan.',
      'Queue and access assistance where available (for example at Vaishno Devi).',
      'Pony, palki or helicopter arrangements on request.',
      'Priest-assisted rituals where appropriate and welcomed.',
      'Comfortable pacing and accessible stays, suitable for elders.',
      'Private vehicle, chauffeur and 24×7 on-trip support.',
    ],
  },
  mountains: {
    title: 'Mountain Journeys',
    hero: '/assets/thumbnails/khajjiar',
    lead: 'Himalayan foothills and hill stations — cool air, high passes and slow, scenic days, with the flexibility that mountain weather asks for.',
    dests: ['shimla_manali', 'dharamshala', 'dalhousie', 'mussoorie', 'nainital', 'rishikesh'],
    includes: [
      'Scenic mountain drives with an experienced hill chauffeur.',
      'Hill-station stays with views — at actual cost plus a transparent 10% coordination fee.',
      'Gentle walks, viewpoints and unhurried time in nature.',
      'Optional light adventure — river rafting in Rishikesh, ropeways and more.',
      'Flexible, weather-aware planning and contingencies.',
      '24×7 on-trip support throughout.',
    ],
  },
  wildlife: {
    title: 'Wildlife Journeys',
    hero: '/assets/thumbnails/ranthambore',
    lead: 'India’s storied tiger reserves and forests, arranged with the permits, timing and naturalists that make sightings — and the wait — worthwhile.',
    dests: ['ranthambore', 'jim_corbett'],
    includes: [
      'Jeep safaris with trained, park-licensed naturalists.',
      'Park permits and safari-zone bookings handled for you.',
      'Lodges and stays at the park edge — at actual cost plus a transparent 10% coordination fee.',
      'Dawn and dusk game drives at the best hours.',
      'Birding and photography focus on request.',
      'Private transfers and 24×7 on-trip support.',
    ],
  },
  luxury: {
    title: 'Luxury Journeys',
    hero: '/assets/thumbnails/udaipur',
    lead: 'Palace hotels, private experiences and a dedicated Journey Manager — the finest of North India, with transparent pricing and no hidden markups.',
    dests: ['udaipur', 'jaipur', 'jodhpur', 'agra', 'ranthambore'],
    includes: [
      'Heritage palace and leading luxury hotel stays — at actual cost plus a transparent 10% coordination fee.',
      'Private experiences: palace dinners, lake boat rides, spa and wellness.',
      'Premium private vehicles with a professional chauffeur.',
      'A dedicated Journey Manager and special-occasion touches.',
      'Priority access and reservations where available.',
      '24×7 on-trip support throughout.',
    ],
  },
};

export function getStaticPaths() {
  return ['heritage', 'spiritual', 'pilgrimage', 'mountains', 'wildlife', 'luxury'].map((interest) => ({
    params: { interest },
  }));
}

const { interest } = Astro.params;
const exp = EXP[interest as string];
const title = `${exp.title} — Ivory Arc Travels`;
const description = exp.lead;
---

<BaseLayout title={title} description={description} canonical={`/experiences/${interest}`}>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden">
    <Picture
      base={exp.hero}
      alt={exp.title}
      width={1200}
      height={800}
      eager
      class="absolute inset-0 -z-10 block h-full w-full"
      imgClass="h-full w-full object-cover"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-teal-900/90 via-teal-900/55 to-teal-900/35"></div>
    <div class="container-ed flex min-h-[44svh] flex-col justify-end py-14 md:py-20">
      <p class="text-xs font-medium uppercase tracking-[0.24em] text-gold">Experiences</p>
      <h1 class="mt-3 max-w-2xl text-display !text-ivory">{exp.title}</h1>
      <p class="mt-4 max-w-xl text-lg text-ivory/85">{exp.lead}</p>
    </div>
  </section>

  <!-- Where it takes you -->
  <section class="container-ed py-16 md:py-24">
    <h2 class="text-h2">Where it takes you</h2>
    <p class="mt-3 max-w-2xl text-muted">A starting palette of places we cover for this kind of journey — woven together, at your pace, into one private route.</p>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        exp.dests.map((key) => (
          <li class="rounded-lg border border-line bg-ivory p-5">
            <h3 class="font-display text-xl text-teal">{DEST[key].name}</h3>
            <p class="mt-1.5 text-sm text-muted">{DEST[key].blurb}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- What's included -->
  <section class="bg-cream">
    <div class="container-ed py-16 md:py-24">
      <h2 class="text-h2">What’s included</h2>
      <ul class="mt-10 grid gap-x-10 gap-y-5 sm:grid-cols-2">
        {
          exp.includes.map((item) => (
            <li class="flex gap-3 border-t border-line pt-4 text-ink/90">
              <svg class="mt-1 size-4 shrink-0 text-teal" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M4 10.5l3.5 3.5L16 5.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-8 max-w-2xl text-sm text-muted">Every journey is fully customised and billed in INR. Hotels are charged at actual cost plus a transparent 10% coordination fee — never a commission.</p>
      <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">
        <CTAButton href="/plan" variant="primary" label="Get an estimate" target="estimator" location="experience_footer" />
        <WhatsAppLink variant="secondary" location="experience_footer" />
      </div>
    </div>
  </section>
</BaseLayout>
