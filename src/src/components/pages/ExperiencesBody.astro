nte dell’India, porta verso le colline.", "ru": "Самый элегантный спланированный город Индии, ворота к холмам."}};

const c = CHROME[lang] ?? CHROME.en;
const title = (TITLE[interest]?.[lang]) ?? TITLE[interest]?.en ?? '';
const lead = (LEAD[interest]?.[lang]) ?? LEAD[interest]?.en ?? '';
const includes: string[] = (INCL[interest]?.[lang]) ?? INCL[interest]?.en ?? [];
const dests: string[] = DESTS[interest] ?? [];
const blurbFor = (k: string) => (BLURB[k]?.[lang]) ?? BLURB[k]?.en ?? '';
const metaTitle = `${title} — Ivory Arc Travels`;
const canonical = lang === 'en' ? `/experiences/${interest}` : `/${lang}/experiences/${interest}`;
---

<BaseLayout title={metaTitle} description={lead} lang={lang} canonical={canonical} hreflangPath={`/experiences/${interest}`}>
  <section class="relative isolate overflow-hidden">
    <Picture base={HERO[interest]} alt={title} width={1200} height={800} eager class="absolute inset-0 -z-10 block h-full w-full" imgClass="h-full w-full object-cover" />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-teal-900/90 via-teal-900/55 to-teal-900/35"></div>
    <div class="container-ed flex min-h-[44svh] flex-col justify-end py-14 md:py-20">
      <p class="text-xs font-medium uppercase tracking-[0.24em] text-gold">{c.eyebrow}</p>
      <h1 class="mt-3 max-w-2xl text-display !text-ivory">{title}</h1>
      <p class="mt-4 max-w-xl text-lg text-ivory/85">{lead}</p>
    </div>
  </section>

  <section class="container-ed py-16 md:py-24">
    <h2 class="text-h2">{c.whereTitle}</h2>
    <p class="mt-3 max-w-2xl text-muted">{c.whereIntro}</p>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        dests.map((key) => (
          <li class="rounded-lg border border-line bg-ivory p-5">
            <h3 class="font-display text-xl text-teal">{NAME[key]}</h3>
            <p class="mt-1.5 text-sm text-muted">{blurbFor(key)}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="bg-cream">
    <div class="container-ed py-16 md:py-24">
      <h2 class="text-h2">{c.includedTitle}</h2>
      <ul class="mt-10 grid gap-x-10 gap-y-5 sm:grid-cols-2">
        {
          includes.map((item) => (
            <li class="flex gap-3 border-t border-line pt-4 text-ink/90">
              <svg class="mt-1 size-4 shrink-0 text-teal" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path d="M4 10.5l3.5 3.5L16 5.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
      <p class="mt-8 max-w-2xl text-sm text-muted">{c.inrNote}</p>
      <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">
        <CTAButton href={lang === 'en' ? '/plan' : `/${lang}/plan`} variant="primary" label={c.cta} target="estimator" location="experience_footer" />
        <WhatsAppLink variant="secondary" location="experience_footer" />
      </div>
    </div>
  </section>
</BaseLayout>
