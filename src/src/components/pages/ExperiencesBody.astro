const LEAD: Record<string, Record<string, string>> = {"heritage": {"en": "Forts, palaces and walled cities — North India’s living history, explored privately with expert guides and never a commission-driven stop.", "es": "Fuertes, palacios y ciudades amuralladas: la historia viva del norte de la India, explorada en privado con guías expertos y sin paradas comerciales.", "de": "Forts, Paläste und ummauerte Städte — die lebendige Geschichte Nordindiens, privat erkundet mit fachkundigen Guides und ohne provisionsgetriebene Stopps.", "fr": "Forts, palais et cités fortifiées — l’histoire vivante du nord de l’Inde, explorée en privé avec des guides experts et sans arrêt commercial.", "it": "Forti, palazzi e città murate: la storia viva dell’India del Nord, esplorata in privato con guide esperte e senza soste commerciali.", "ru": "Форты, дворцы и города-крепости — живая история Северной Индии, которую вы исследуете частно с опытными гидами и без коммерческих остановок."}, "spiritual": {"en": "Sacred rivers, temple towns and the quiet energy of North India’s holiest places — arranged with care and respect for every tradition.", "es": "Ríos sagrados, ciudades-templo y la energía serena de los lugares más sagrados del norte de la India, organizados con cuidado y respeto por cada tradición.", "de": "Heilige Flüsse, Tempelstädte und die stille Energie der heiligsten Orte Nordindiens — mit Sorgfalt und Respekt für jede Tradition arrangiert.", "fr": "Rivières sacrées, villes-temples et l’énergie paisible des lieux les plus sacrés du nord de l’Inde — organisés avec soin et respect de chaque tradition.", "it": "Fiumi sacri, città-tempio e la quiete energia dei luoghi più sacri dell’India del Nord, organizzati con cura e rispetto per ogni tradizione.", "ru": "Священные реки, храмовые города и тихая энергия самых святых мест Северной Индии — организовано с заботой и уважением к каждой традиции."}, "pilgrimage": {"en": "The classic yatras and shrines of the north, arranged end to end 