---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import Picture from '../Picture.astro';
import CTAButton from '../CTAButton.astro';
import WhatsAppLink from '../WhatsAppLink.astro';
import { SITE } from '../../consts';
import type { Lang } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;

// Language-neutral: photo + proper-noun name + region. Descriptions are translated below.
const places: { key: string; img?: string; name: string; region: string }[] = [
  { key: 'agra', img: '/assets/photos/agra', name: 'Agra', region: 'Uttar Pradesh' },
  { key: 'delhi', img: '/assets/photos/delhi-humayun', name: 'Delhi', region: 'Delhi NCR' },
  { key: 'jaipur', img: '/assets/photos/jaipur', name: 'Jaipur', region: 'Rajasthan' },
  { key: 'varanasi', img: '/assets/destinations/varanasi/varanasi-aarti', name: 'Varanasi', region: 'Uttar Pradesh' },
  { key: 'mathura', img: '/assets/photos/mathura', name: 'Mathura & Vrindavan', region: 'Uttar Pradesh' },
  { key: 'haridwar', img: '/assets/photos/rishikesh', name: 'Haridwar & Rishikesh', region: 'Uttarakhand' },
  { key: 'amritsar', img: '/assets/photos/amritsar', name: 'Amritsar', region: 'Punjab' },
  { key: 'udaipur', img: '/assets/thumbnails/udaipur', name: 'Udaipur', region: 'Rajasthan' },
  { key: 'jodhpur', img: '/assets/thumbnails/jodhpur', name: 'Jodhpur', region: 'Rajasthan' },
  { key: 'jaisalmer', img: '/assets/thumbnails/jaisalmer', name: 'Jaisalmer', region: 'Rajasthan' },
  { key: 'pushkar', img: '/assets/thumbnails/pushkar', name: 'Pushkar', region: 'Rajasthan' },
  { key: 'bikaner', img: '/assets/thumbnails/bikaner', name: 'Bikaner', region: 'Rajasthan' },
  { key: 'ranthambore', img: '/assets/thumbnails/ranthambore', name: 'Ranthambore', region: 'Rajasthan' },
  { key: 'corbett', img: '/assets/photos/corbett', name: 'Jim Corbett', region: 'Uttarakhand' },
  { key: 'ayodhya', img: '/assets/thumbnails/ayodhya', name: 'Ayodhya', region: 'Uttar Pradesh' },
  { key: 'khajjiar', img: '/assets/thumbnails/khajjiar', name: 'Khajjiar', region: 'Himachal Pradesh' },
  { key: 'solang', img: '/assets/thumbnails/solang-valley', name: 'Solang Valley', region: 'Himachal Pradesh' },
  { key: 'patiala', img: '/assets/thumbnails/patiala', name: 'Patiala', region: 'Punjab' },
  { key: 'vaishno', img: '/assets/thumbnails/vaishno-devi', name: 'Vaishno Devi', region: 'Jammu' },
];

const C: Record<string, any> = {
  en: { mt: 'Destinations — Ivory Arc Travels', md: `Where we travel across North India — ${SITE.destinationCount} destinations and counting. Private journeys shaped around you.`, eyebrow: 'Destinations', h1: 'Where we travel.', intro: `We plan private journeys across the length and breadth of North India — ${SITE.destinationCount} destinations in all, from the palaces of Rajasthan to the Ganges, the Himalaya, the tiger forests and the holiest pilgrimage sites. Each place below is a starting point, never a fixed package.`,
    reasons: [ { t: 'The length & breadth of North India', d: `${SITE.destinationCount} destinations and counting — from the Himalaya to the Thar, the Ganga plains to the Sutlej.` }, { t: 'Every kind of place covered', d: 'Heritage cities, sacred rivers, tiger forests, mountain valleys and the great pilgrimage trails — all on one itinerary if you like.' }, { t: 'However complex, we\u2019ve got your back', d: 'One team and one point of contact, start to finish — no matter how many cities or special requests your plan involves.' } ],
    moreT: `Many more across the region`, moreD: `These are highlights — we cover ${SITE.destinationCount} destinations in all. Tell us where you dream of going.`, cta: 'Plan your journey',
    notes: { agra: 'The Taj Mahal — the monument the world comes to see, plus Agra Fort and Fatehpur Sikri.', delhi: "India's capital — Humayun's Tomb, the Red Fort and Qutub Minar; the start of the Golden Triangle.", jaipur: 'The Pink City — Hawa Mahal, Amber Fort and royal bazaars; the third point of the Golden Triangle.', varanasi: 'The eternal city — dawn boats on the Ganga and the lamp-lit evening aarti.', mathura: "Krishna's birthplace — twin temple towns of devotion on the Yamuna.", haridwar: 'Where the Ganga leaves the mountains — the Ganga aarti, ashrams and the yoga capital of the world.', amritsar: "The Golden Temple — Sikhism's holiest shrine, gold on water, and the Wagah border ceremony.", udaipur: 'Lake palaces, marble courtyards and sunset boats on Lake Pichola.', jodhpur: 'The blue city beneath the ramparts of Mehrangarh Fort.', jaisalmer: 'A living golden-sandstone fort on the edge of the Thar Desert.', pushkar: 'A sacred lake town of ghats, temples and the famous camel fair.', bikaner: 'Junagarh Fort, ornate havelis and old Silk Road trade routes.', ranthambore: "India's most storied tiger reserve, wrapped around a hilltop fort.", corbett: "India's oldest national park — tiger country in the Himalayan foothills.", ayodhya: 'The Ram Mandir and the spiritual heart of the Sarayu riverlands.', khajjiar: 'Alpine meadows ringed by deodar forest — the “mini Switzerland”.', solang: 'High-altitude adventure and snow above the Manali valley.', patiala: 'Royal Punjab — Qila Mubarak, gardens and a living court culture.', vaishno: "One of India's most revered pilgrimages, in the Trikuta hills." } },
  es: { mt: 'Destinos — Ivory Arc Travels', md: `Dónde viajamos por el norte de la India: ${SITE.destinationCount} destinos y creciendo. Viajes privados diseñados para ti.`, eyebrow: 'Destinos', h1: 'Dónde viajamos.', intro: `Planificamos viajes privados por todo el norte de la India: ${SITE.destinationCount} destinos en total, desde los palacios de Rajastán hasta el Ganges, el Himalaya, los bosques de tigres y los lugares de peregrinación más sagrados. Cada lugar es un punto de partida, nunca un paquete fijo.`,
    reasons: [ { t: 'A lo largo y ancho del norte de la India', d: `${SITE.destinationCount} destinos y creciendo: del Himalaya al Thar, de las llanuras del Ganges al Sutlej.` }, { t: 'Todo tipo de lugares', d: 'Ciudades históricas, ríos sagrados, bosques de tigres, valles de montaña y las grandes rutas de peregrinación, todo en un itinerario si quieres.' }, { t: 'Por complejo que sea, te cubrimos', d: 'Un solo equipo y un único contacto, de principio a fin, sin importar cuántas ciudades o peticiones especiales tenga tu plan.' } ],
    moreT: 'Muchos más por la región', moreD: `Estos son destacados: cubrimos ${SITE.destinationCount} destinos en total. Dinos a dónde sueñas con ir.`, cta: 'Planifica tu viaje',
    notes: { agra: 'El Taj Mahal, el monumento que el mundo viene a ver, además del Fuerte de Agra y Fatehpur Sikri.', delhi: 'La capital de la India: la Tumba de Humayun, el Fuerte Rojo y el Qutub Minar; el inicio del Triángulo de Oro.', jaipur: 'La Ciudad Rosa: Hawa Mahal, el Fuerte Amber y bazares reales; el tercer punto del Triángulo de Oro.', varanasi: 'La ciudad eterna: barcas al amanecer en el Ganges y la aarti vespertina iluminada.', mathura: 'La cuna de Krishna: ciudades-templo gemelas de devoción a orillas del Yamuna.', haridwar: 'Donde el Ganges deja las montañas: la aarti del Ganges, ashrams y la capital mundial del yoga.', amritsar: 'El Templo Dorado, el santuario más sagrado del sijismo, oro sobre el agua, y la ceremonia de Wagah.', udaipur: 'Palacios sobre el lago, patios de mármol y barcas al atardecer en el lago Pichola.', jodhpur: 'La ciudad azul al pie de las murallas del Fuerte Mehrangarh.', jaisalmer: 'Un fuerte vivo de arenisca dorada al borde del desierto del Thar.', pushkar: 'Una sagrada ciudad lacustre de ghats, templos y la famosa feria de camellos.', bikaner: 'El Fuerte Junagarh, havelis ornamentadas y antiguas rutas de la Ruta de la Seda.', ranthambore: 'La reserva de tigres más legendaria de la India, en torno a un fuerte en lo alto.', corbett: 'El parque nacional más antiguo de la India: territorio de tigres en las estribaciones del Himalaya.', ayodhya: 'El Ram Mandir y el corazón espiritual de las tierras del río Sarayu.', khajjiar: 'Praderas alpinas rodeadas de bosque de cedros, la “mini Suiza”.', solang: 'Aventura de altura y nieve sobre el valle de Manali.', patiala: 'El Punjab real: Qila Mubarak, jardines y una cultura cortesana viva.', vaishno: 'Una de las peregrinaciones más veneradas de la India, en las colinas de Trikuta.' } },
  de: { mt: 'Reiseziele — Ivory Arc Travels', md: `Wohin wir in Nordindien reisen — ${SITE.destinationCount} Reiseziele und mehr. Private Reisen, um Sie herum gestaltet.`, eyebrow: 'Reiseziele', h1: 'Wohin wir reisen.', intro: `Wir planen private Reisen durch ganz Nordindien — ${SITE.destinationCount} Reiseziele insgesamt, von den Palästen Rajasthans bis zum Ganges, dem Himalaya, den Tigerwäldern und den heiligsten Pilgerstätten. Jeder Ort ist ein Ausgangspunkt, nie ein festes Paket.`,
    reasons: [ { t: 'Die ganze Weite Nordindiens', d: `${SITE.destinationCount} Reiseziele und mehr — vom Himalaya bis zur Thar, von der Ganges-Ebene bis zum Sutlej.` }, { t: 'Jede Art von Ort', d: 'Historische Städte, heilige Flüsse, Tigerwälder, Bergtäler und die großen Pilgerwege — auf Wunsch alles in einer Reiseroute.' }, { t: 'Wie komplex auch immer, wir kümmern uns', d: 'Ein Team und ein Ansprechpartner, von Anfang bis Ende — egal wie viele Städte oder Sonderwünsche Ihr Plan umfasst.' } ],
    moreT: 'Viele weitere in der Region', moreD: `Dies sind Highlights — wir decken insgesamt ${SITE.destinationCount} Reiseziele ab. Sagen Sie uns, wohin Sie träumen.`, cta: 'Reise planen',
    notes: { agra: 'Das Taj Mahal — das Monument, das die Welt sehen will, dazu Agra Fort und Fatehpur Sikri.', delhi: 'Indiens Hauptstadt — Humayuns Grab, das Rote Fort und Qutub Minar; der Beginn des Goldenen Dreiecks.', jaipur: 'Die Rosa Stadt — Hawa Mahal, Amber Fort und königliche Basare; der dritte Punkt des Goldenen Dreiecks.', varanasi: 'Die ewige Stadt — Boote im Morgengrauen auf dem Ganges und die abendliche Lichter-Aarti.', mathura: 'Krishnas Geburtsort — zwei Tempelstädte der Hingabe am Yamuna.', haridwar: 'Wo der Ganges die Berge verlässt — die Ganga-Aarti, Ashrams und die Yoga-Welthauptstadt.', amritsar: 'Der Goldene Tempel — das heiligste Heiligtum des Sikhismus, Gold auf dem Wasser, und die Wagah-Zeremonie.', udaipur: 'Seepaläste, Marmorhöfe und Sonnenuntergangsboote auf dem Pichola-See.', jodhpur: 'Die blaue Stadt unter den Mauern des Mehrangarh Fort.', jaisalmer: 'Ein lebendiges Fort aus goldenem Sandstein am Rand der Thar-Wüste.', pushkar: 'Eine heilige Seestadt mit Ghats, Tempeln und der berühmten Kamelmesse.', bikaner: 'Junagarh Fort, kunstvolle Havelis und alte Seidenstraßen-Routen.', ranthambore: 'Indiens sagenumwobenstes Tigerreservat, rund um ein Hügelfort.', corbett: 'Indiens ältester Nationalpark — Tigerland in den Ausläufern des Himalaya.', ayodhya: 'Der Ram Mandir und das spirituelle Herz des Sarayu-Flusslands.', khajjiar: 'Almwiesen umringt von Zedernwald — die „Mini-Schweiz“.', solang: 'Hochgebirgsabenteuer und Schnee über dem Manali-Tal.', patiala: 'Königliches Punjab — Qila Mubarak, Gärten und lebendige Hofkultur.', vaishno: 'Eine der verehrtesten Pilgerfahrten Indiens, in den Trikuta-Hügeln.' } },
  fr: { mt: 'Destinations — Ivory Arc Travels', md: `Où nous voyageons dans le nord de l'Inde — ${SITE.destinationCount} destinations et plus. Des voyages privés conçus autour de vous.`, eyebrow: 'Destinations', h1: 'Où nous voyageons.', intro: `Nous concevons des voyages privés dans tout le nord de l'Inde — ${SITE.destinationCount} destinations en tout, des palais du Rajasthan au Gange, à l'Himalaya, aux forêts de tigres et aux sites de pèlerinage les plus sacrés. Chaque lieu est un point de départ, jamais un forfait figé.`,
    reasons: [ { t: "Tout le nord de l'Inde", d: `${SITE.destinationCount} destinations et plus — de l'Himalaya au Thar, des plaines du Gange au Sutlej.` }, { t: 'Tous les types de lieux', d: 'Villes patrimoniales, rivières sacrées, forêts de tigres, vallées de montagne et grands chemins de pèlerinage — tout en un itinéraire si vous le souhaitez.' }, { t: 'Aussi complexe soit-il, on gère', d: 'Une équipe et un seul interlocuteur, du début à la fin — quel que soit le nombre de villes ou de demandes spéciales.' } ],
    moreT: 'Bien d\u2019autres dans la région', moreD: `Ce sont des points forts — nous couvrons ${SITE.destinationCount} destinations en tout. Dites-nous où vous rêvez d'aller.`, cta: 'Planifiez votre voyage',
    notes: { agra: 'Le Taj Mahal — le monument que le monde vient voir, plus le Fort d\u2019Agra et Fatehpur Sikri.', delhi: "La capitale de l'Inde — le tombeau de Humayun, le Fort Rouge et le Qutub Minar ; le départ du Triangle d'Or.", jaipur: "La Ville rose — Hawa Mahal, le Fort d'Amber et les bazars royaux ; le troisième point du Triangle d'Or.", varanasi: "La ville éternelle — barques à l'aube sur le Gange et l'aarti du soir illuminée.", mathura: 'Le lieu de naissance de Krishna — deux villes-temples de dévotion sur la Yamuna.', haridwar: "Là où le Gange quitte les montagnes — l'aarti du Gange, les ashrams et la capitale mondiale du yoga.", amritsar: "Le Temple d'Or — le sanctuaire le plus sacré du sikhisme, l'or sur l'eau, et la cérémonie de Wagah.", udaipur: 'Palais sur le lac, cours de marbre et barques au coucher du soleil sur le lac Pichola.', jodhpur: 'La ville bleue au pied des remparts du Fort de Mehrangarh.', jaisalmer: 'Un fort vivant de grès doré en bordure du désert du Thar.', pushkar: 'Une ville sacrée au bord du lac, ses ghats, ses temples et sa célèbre foire aux chameaux.', bikaner: 'Le Fort Junagarh, des havelis ornées et d\u2019anciennes routes de la soie.', ranthambore: "La réserve de tigres la plus légendaire de l'Inde, autour d'un fort perché.", corbett: "Le plus ancien parc national de l'Inde — pays du tigre dans les contreforts de l'Himalaya.", ayodhya: 'Le Ram Mandir et le cœur spirituel des terres de la rivière Sarayu.', khajjiar: 'Des prairies alpines cernées de cèdres — la « mini-Suisse ».', solang: 'Aventure en altitude et neige au-dessus de la vallée de Manali.', patiala: 'Le Pendjab royal — Qila Mubarak, jardins et culture de cour vivante.', vaishno: "L'un des pèlerinages les plus vénérés de l'Inde, dans les collines de Trikuta." } },
  it: { mt: 'Destinazioni — Ivory Arc Travels', md: `Dove viaggiamo nell'India del Nord — ${SITE.destinationCount} destinazioni e oltre. Viaggi privati costruiti intorno a te.`, eyebrow: 'Destinazioni', h1: 'Dove viaggiamo.', intro: `Pianifichiamo viaggi privati in tutta l'India del Nord — ${SITE.destinationCount} destinazioni in tutto, dai palazzi del Rajasthan al Gange, all'Himalaya, alle foreste delle tigri e ai luoghi di pellegrinaggio più sacri. Ogni luogo è un punto di partenza, mai un pacchetto fisso.`,
    reasons: [ { t: "In lungo e in largo per l'India del Nord", d: `${SITE.destinationCount} destinazioni e oltre — dall'Himalaya al Thar, dalle pianure del Gange al Sutlej.` }, { t: 'Ogni tipo di luogo', d: 'Città storiche, fiumi sacri, foreste di tigri, valli di montagna e i grandi percorsi di pellegrinaggio — tutto in un itinerario, se vuoi.' }, { t: 'Per quanto complesso, ci pensiamo noi', d: 'Un solo team e un unico referente, dall\u2019inizio alla fine, indipendentemente da quante città o richieste speciali preveda il tuo piano.' } ],
    moreT: 'Molte altre nella regione', moreD: `Questi sono i punti salienti — copriamo ${SITE.destinationCount} destinazioni in tutto. Dicci dove sogni di andare.`, cta: 'Pianifica il tuo viaggio',
    notes: { agra: 'Il Taj Mahal — il monumento che il mondo viene a vedere, oltre al Forte di Agra e Fatehpur Sikri.', delhi: "La capitale dell'India — la Tomba di Humayun, il Forte Rosso e il Qutub Minar; l'inizio del Triangolo d'Oro.", jaipur: "La Città Rosa — Hawa Mahal, il Forte Amber e i bazar reali; il terzo punto del Triangolo d'Oro.", varanasi: 'La città eterna — barche all\u2019alba sul Gange e l\u2019aarti serale illuminata.', mathura: 'Il luogo di nascita di Krishna — due città-tempio di devozione sulla Yamuna.', haridwar: "Dove il Gange lascia le montagne — l'aarti del Gange, gli ashram e la capitale mondiale dello yoga.", amritsar: "Il Tempio d'Oro — il santuario più sacro del sikhismo, oro sull'acqua, e la cerimonia di Wagah.", udaipur: 'Palazzi sul lago, cortili di marmo e barche al tramonto sul lago Pichola.', jodhpur: 'La città blu ai piedi delle mura del Forte Mehrangarh.', jaisalmer: 'Un forte vivente di arenaria dorata ai margini del deserto del Thar.', pushkar: 'Una sacra città lacustre di ghat, templi e la celebre fiera dei cammelli.', bikaner: 'Il Forte Junagarh, havelì ornate e antiche rotte della Via della Seta.', ranthambore: "La riserva di tigri più leggendaria dell'India, attorno a un forte in collina.", corbett: "Il più antico parco nazionale dell'India — terra di tigri ai piedi dell'Himalaya.", ayodhya: 'Il Ram Mandir e il cuore spirituale delle terre del fiume Sarayu.', khajjiar: 'Prati alpini circondati da cedri — la “mini Svizzera”.', solang: 'Avventura d\u2019alta quota e neve sopra la valle di Manali.', patiala: 'Il Punjab regale — Qila Mubarak, giardini e una cultura di corte viva.', vaishno: "Uno dei pellegrinaggi più venerati dell'India, sulle colline di Trikuta." } },
  ru: { mt: 'Направления — Ivory Arc Travels', md: `Куда мы ездим по Северной Индии — ${SITE.destinationCount} направлений и больше. Частные путешествия, созданные вокруг вас.`, eyebrow: 'Направления', h1: 'Куда мы ездим.', intro: `Мы планируем частные путешествия по всей Северной Индии — всего ${SITE.destinationCount} направлений, от дворцов Раджастана до Ганга, Гималаев, тигриных лесов и святейших мест паломничества. Каждое место — отправная точка, а не фиксированный пакет.`,
    reasons: [ { t: 'Вся Северная Индия', d: `${SITE.destinationCount} направлений и больше — от Гималаев до Тара, от равнин Ганга до Сатледжа.` }, { t: 'Любые места', d: 'Исторические города, священные реки, тигриные леса, горные долины и великие паломнические пути — всё в одном маршруте, если хотите.' }, { t: 'Каким бы сложным ни был план — мы справимся', d: 'Одна команда и один контакт от начала до конца, сколько бы городов или особых пожеланий ни было в вашем плане.' } ],
    moreT: 'И много других в регионе', moreD: `Это лишь основные — всего мы охватываем ${SITE.destinationCount} направлений. Скажите, куда мечтаете поехать.`, cta: 'Планировать путешествие',
    notes: { agra: 'Тадж-Махал — памятник, который едет смотреть весь мир, плюс форт Агры и Фатехпур-Сикри.', delhi: 'Столица Индии — гробница Хумаюна, Красный форт и Кутб-Минар; начало Золотого треугольника.', jaipur: 'Розовый город — Хава-Махал, форт Амбер и царские базары; третья точка Золотого треугольника.', varanasi: 'Вечный город — лодки на рассвете по Гангу и вечерняя аарти при свете огней.', mathura: 'Место рождения Кришны — два храмовых города преданности на Ямуне.', haridwar: 'Где Ганг выходит из гор — аарти Ганга, ашрамы и мировая столица йоги.', amritsar: 'Золотой храм — святыня сикхизма, золото над водой, и церемония на границе Вагах.', udaipur: 'Дворцы на озере, мраморные дворы и закатные лодки на озере Пичола.', jodhpur: 'Синий город под стенами форта Мехрангарх.', jaisalmer: 'Живой форт из золотистого песчаника на краю пустыни Тар.', pushkar: 'Священный озёрный город гхатов, храмов и знаменитой верблюжьей ярмарки.', bikaner: 'Форт Джунагарх, украшенные хавели и старые торговые пути Шёлкового пути.', ranthambore: 'Самый легендарный тигриный заповедник Индии вокруг форта на холме.', corbett: 'Старейший национальный парк Индии — страна тигров в предгорьях Гималаев.', ayodhya: 'Рам-Мандир и духовное сердце земель реки Сараю.', khajjiar: 'Альпийские луга в кольце кедрового леса — «мини-Швейцария».', solang: 'Высокогорные приключения и снег над долиной Манали.', patiala: 'Царский Пенджаб — Кила Мубарак, сады и живая придворная культура.', vaishno: 'Одно из самых почитаемых паломничеств Индии, в холмах Трикута.' } },
};
const c = C[lang] ?? C.en;
const canonical = lang === 'en' ? '/destinations' : `/${lang}/destinations`;
---
<BaseLayout title={c.mt} description={c.md} lang={lang} canonical={canonical} hreflangPath="/destinations">
  <section class="container-ed py-16 md:py-24">
    <SectionHeading eyebrow={c.eyebrow} title={c.h1} intro={c.intro} align="left" />

    <dl class="mt-8 grid gap-4 sm:grid-cols-3">
      {c.reasons.map((r: any) => (
        <div class="rounded-lg border-l-2 border-gold bg-cream px-5 py-4">
          <dt class="font-display text-lg text-ink">{r.t}</dt>
          <dd class="mt-1 text-sm text-muted">{r.d}</dd>
        </div>
      ))}
    </dl>

    <ul class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-5">
      {places.map((p) => (
        <li>
          <article class="group h-full overflow-hidden rounded-lg border border-line bg-ivory">
            <div class="relative aspect-[4/3] overflow-hidden bg-cream">
              {p.img ? (
                <Picture base={p.img} alt={p.name} width={480} height={360} sizes="(min-width:768px) 33vw, 50vw" class="block h-full w-full" imgClass="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-gold/40"><svg viewBox="0 0 48 48" class="size-10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M24 4l16 9v22L24 44 8 35V13z" /></svg></div>
              )}
            </div>
            <div class="p-4">
              <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-gold-600">{p.region}</p>
              <h3 class="mt-0.5 font-display text-lg text-teal">{p.name}</h3>
              <p class="mt-1 text-sm text-muted">{c.notes[p.key]}</p>
            </div>
          </article>
        </li>
      ))}
      <li>
        <div class="flex h-full flex-col justify-center rounded-lg border border-dashed border-gold/50 bg-cream p-5 text-center">
          <p class="font-display text-lg text-teal">{c.moreT}</p>
          <p class="mt-1 text-sm text-muted">{c.moreD}</p>
        </div>
      </li>
    </ul>

    <div class="mt-12 flex flex-col items-start gap-3 sm:flex-row">
      <CTAButton href={lang === 'en' ? '/plan' : `/${lang}/plan`} variant="primary" label={c.cta} target="estimator" location="destinations_footer" />
      <WhatsAppLink variant="secondary" location="destinations_footer" />
    </div>
  </section>
</BaseLayout>
