---
/*
  <picture> with AVIF then WebP, matching the optimized asset pairs.
  Pass `base` as the path without extension, e.g. "/assets/destinations/patiala".
  Set `eager` for the LCP image; everything else lazy-loads on scroll.
  width/height are required to reserve space and prevent layout shift.
*/
interface Props {
  base: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  eager?: boolean;
  class?: string;
  imgClass?: string;
}
const {
  base,
  alt,
  width,
  height,
  sizes,
  eager = false,
  class: cls,
  imgClass,
} = Astro.props;
---
<picture class={cls}>
  <source srcset={`${base}.avif`} type="image/avif" sizes={sizes} />
  <source srcset={`${base}.webp`} type="image/webp" sizes={sizes} />
  <img
    src={`${base}.webp`}
    alt={alt}
    width={width}
    height={height}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
    class={imgClass}
  />
</picture>
