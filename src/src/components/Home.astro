---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from './Hero.astro';
import TrustStrip from './TrustStrip.astro';
import PricingSteps from './PricingSteps.astro';
import InterestGrid from './InterestGrid.astro';
import SampleJourneys from './SampleJourneys.astro';
import WhyIvoryArc from './WhyIvoryArc.astro';
import IvyExplainer from './IvyExplainer.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const canonical = lang === 'en' ? '/' : `/${lang}`;
---
<BaseLayout
  title={t('meta.title')}
  description={t('meta.description')}
  lang={lang}
  canonical={canonical}
  hreflangPath="/"
  transparentHeader={true}
>
  <Hero lang={lang} />
  <TrustStrip lang={lang} />
  <PricingSteps lang={lang} />
  <InterestGrid lang={lang} />
  <SampleJourneys lang={lang} />
  <WhyIvoryArc lang={lang} />
  <IvyExplainer lang={lang} />
</BaseLayout>
