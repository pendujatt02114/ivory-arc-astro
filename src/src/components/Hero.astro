---
import Picture from './Picture.astro';
import WhatsAppLink from './WhatsAppLink.astro';
import CTAButton from './CTAButton.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---
<section class="relative isolate overflow-hidden">
  <Picture
    base="/assets/heroes/hero-home"
    alt="The Taj Mahal at dawn, Agra"
    width={1600}
    height={900}
    eager
    class="absolute inset-0 -z-10 block h-full w-full"
    imgClass="h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-t from-teal-900/85 via-teal-900/40 to-teal-900/25"></div>

  <div class="container-ed flex min-h-[80svh] flex-col justify-end pb-14 pt-20 md:pb-20">
    <p class="text-xs font-medium uppercase tracking-[0.24em] text-gold">{t('hero.eyebrow')}</p>
    <h1 class="mt-4 max-w-2xl text-display !text-ivory">{t('hero.title')}</h1>
    <p class="mt-5 max-w-xl text-lg text-ivory/85">{t('hero.sub')}</p>
    <div class="mt-8 flex w-full flex-col items-stretch gap-3 sm:w-auto sm:flex-row">
      <WhatsAppLink variant="primary" location="hero" label={t('cta.ivy')} />
      <CTAButton
        href="/plan"
        variant="secondary-light"
        label={t('cta.estimate')}
        target="estimator"
        location="hero"
      />
    </div>
    <p class="mt-6 max-w-md text-sm text-ivory/70">{t('hero.aside')}</p>
  </div>
</section>
