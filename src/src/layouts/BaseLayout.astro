---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { SITE, WHATSAPP } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileConversionBar from '../components/MobileConversionBar.astro';
import JsonLd from '../components/JsonLd.astro';
import { LANGS, defaultLang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  canonical?: string; // path ('/x') or absolute URL
  image?: string; // OG image path or absolute URL
  lang?: string;
  transparentHeader?: boolean;
  barEmphasis?: 'estimate' | 'ivy';
  noBar?: boolean;
  hreflangPath?: string; // when set, emit hreflang alternates for this path (e.g. '/', '/about')
}
const {
  title,
  description,
  canonical = '/',
  image = '/brand/logo.png',
  lang = 'en',
  transparentHeader = false,
  barEmphasis = 'estimate',
  noBar = false,
  hreflangPath,
} = Astro.props;

const abs = (p: string) => (p.startsWith('http') ? p : SITE.domain + p);
const canonicalUrl = abs(canonical);
const ogImage = abs(image);

// hreflang alternates (architecture §10). Home → '/', '/es', '/de'…; interior → '/about', '/es/about'…
const altHref = (loc: string) => {
  const path = hreflangPath ?? '/';
  if (path === '/') return SITE.domain + (loc === defaultLang ? '/' : `/${loc}`);
  return SITE.domain + (loc === defaultLang ? '' : `/${loc}`) + path;
};

// Sitewide Organization + TravelAgency (architecture §13). Page-level schema
// (Destination, Trip, FAQ, Breadcrumb) is added per-page in later batches.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'TravelAgency'],
  '@id': SITE.domain + '/#org',
  name: SITE.name,
  url: SITE.domain,
  logo: SITE.domain + '/brand/logo.png',
  image: SITE.domain + '/brand/logo.png',
  slogan: SITE.tagline,
  description:
    'Private luxury travel atelier designing bespoke heritage and spiritual journeys across North India. Transparent pricing, no commission-driven shopping stops.',
  areaServed: [
    'Delhi NCR',
    'Rajasthan',
    'Uttar Pradesh',
    'Uttarakhand',
    'Punjab',
    'Himachal Pradesh',
    'Jammu',
  ],
  vatID: SITE.gst,
  taxID: SITE.gst,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    telephone: '+' + WHATSAPP.ivy,
    availableLanguage: ['en', 'es', 'de', 'fr'],
  },
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e4a47" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl} />
    {
      hreflangPath && (
        <>
          {LANGS.map((loc) => (
            <link rel="alternate" hreflang={loc} href={altHref(loc)} />
          ))}
          <link rel="alternate" hreflang="x-default" href={altHref(defaultLang)} />
        </>
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <JsonLd schema={orgSchema} />
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header transparent={transparentHeader} />
    <main id="main"><slot /></main>
    <Footer />
    {!noBar && <MobileConversionBar emphasis={barEmphasis} />}
    {!noBar && <div class="cb-spacer lg:hidden" aria-hidden="true"></div>}

    {/* Ogee-arch clip path (objectBoundingBox) for .arch-frame — defined once. */}
    <svg width="0" height="0" aria-hidden="true" style="position:absolute">
      <defs>
        <clipPath id="ivory-arch" clipPathUnits="objectBoundingBox">
          <path
            d="M.5 .0167C.54 .1167 .6 .15 .64 .2167C.72 .3167 .8 .3333 .8 .5L.8 .9833L.2 .9833L.2 .5C.2 .3333 .28 .3167 .36 .2167C.4 .15 .46 .1167 .5 .0167Z"
          ></path>
        </clipPath>
      </defs>
    </svg>

    <script>
      import '../lib/analytics.ts';
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 100;
    background: var(--color-teal);
    color: var(--color-ivory);
    padding: 0.6rem 1rem;
    border-radius: 0 0 0.4rem 0;
  }
  .skip-link:focus {
    left: 0;
  }
  .cb-spacer {
    height: calc(4.25rem + env(safe-area-inset-bottom));
  }
</style>
