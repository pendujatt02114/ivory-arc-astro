---
import CTAButton from './CTAButton.astro';
import { waHref, IVY_DEFAULT_MESSAGE, type WaAgent } from '../lib/whatsapp';

interface Props {
  agent?: WaAgent;
  message?: string;
  label?: string;
  variant?: 'primary' | 'secondary' | 'secondary-light' | 'tertiary';
  location?: string;
  class?: string;
}
const {
  agent = 'ivy',
  message,
  label = agent === 'ivy' ? 'Chat with IVY' : 'Speak to a specialist',
  variant = 'primary',
  location,
  class: cls,
} = Astro.props;

const href = waHref(agent, message ?? (agent === 'ivy' ? IVY_DEFAULT_MESSAGE : undefined));
---
<CTAButton
  href={href}
  variant={variant}
  label={label}
  target={agent}
  location={location}
  external
  class={cls}
/>
