---
import { SITE } from '../consts';
import WhatsAppLink from './WhatsAppLink.astro';
import Picture from './Picture.astro';

const year = new Date().getFullYear();

const groups = [
  {
    title: 'Explore',
    links: [
      { h: '/destinations', l: 'Destinations' },
      { h: '/#experiences', l: 'Experiences' },
      { h: '/#journeys', l: 'Sample Journeys' },
    ],
  },
  {
    title: 'Plan',
    links: [
      { h: '/plan', l: 'Plan Your Journey' },
      { h: '/#how-it-works', l: 'How It Works' },
      { h: '/#why', l: 'Why Ivory Arc' },
    ],
  },
  {
    title: 'Company',
    links: [
      { h: '/about', l: 'About' },
      { h: '/contact', l: 'Contact' },
      { h: '/faq', l: 'FAQ' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { h: '/legal/privacy', l: 'Privacy Policy' },
      { h: '/legal/terms', l: 'Terms & Conditions' },
      { h: '/legal/refund', l: 'Refund Policy' },
      { h: '/legal/cancellation', l: 'Cancellation Policy' },
    ],
  },
];
---
<footer class="bg-teal text-ivory">
  <div class="container-ed grid gap-10 py-14 md:grid-cols-12">
    <div class="md:col-span-4">
      <a href="/" class="inline-flex items-center gap-2.5" aria-label={`${SITE.name} — home`}>
        <img src="/brand/logo-mark.webp" width="274" height="240" alt="" class="h-10 w-auto" />
        <span class="font-display text-xl text-ivory">Ivory Arc Travels</span>
      </a>
      <p class="mt-4 max-w-xs text-sm text-ivory/75">
        {SITE.tagline}. Private, fully customized journeys across North India —
        transparent pricing, no commission-driven shopping stops.
      </p>
      <div class="mt-5">
        <WhatsAppLink variant="secondary-light" location="footer" class="!min-h-[44px] !px-5 !text-sm" />
      </div>
    </div>

    {
      groups.map((g) => (
        <nav class="md:col-span-2" aria-label={g.title}>
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-gold">{g.title}</h2>
          <ul class="mt-4 space-y-2.5">
            {g.links.map((x) => (
              <li>
                <a href={x.h} class="text-sm text-ivory/80 transition-colors hover:text-ivory">
                  {x.l}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-t border-ivory/15" style="background-color:#16403f">
    <div class="container-ed flex flex-col items-center gap-5 py-8">
      <Picture
        base="/brand/payment/razorpay-strip"
        alt="Powered by Razorpay — we accept Visa, Mastercard, American Express, Discover and RuPay"
        width={1100}
        height={550}
        sizes="(min-width: 768px) 448px, 100vw"
        class="block w-full max-w-md"
        imgClass="h-auto w-full"
      />
      <p class="text-center text-xs text-ivory/70">
        GST {SITE.gst} · Billed in INR · Currency display is indicative only
      </p>
    </div>
  </div>

  <div class="container-ed pb-8 pt-2 text-xs text-ivory/55">
    © {year} {SITE.name}. All rights reserved.
  </div>
</footer>
