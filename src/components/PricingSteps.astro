---
import SectionHeading from './SectionHeading.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
// All copy is localised via t() — keys live in src/i18n/ui.ts for every language.
const steps = [1, 2, 3, 4, 5] as const;
---
<section id="how-it-works" class="scroll-mt-24 bg-cream">
  <div class="container-ed py-16 md:py-24">
    <SectionHeading
      eyebrow={t('pricing.eyebrow')}
      title={t('pricing.title')}
      intro={t('pricing.intro')}
    />

    <ol class="mt-12 space-y-8 md:space-y-10">
      {
        steps.map((n) => (
          <li class="grid gap-3 sm:grid-cols-[auto_1fr] sm:gap-6">
            <div class="flex items-baseline gap-3 sm:flex-col sm:items-start sm:gap-2">
              <span class="font-display text-4xl leading-none text-teal">{String(n).padStart(2, '0')}</span>
              <span class="h-0.5 w-10 rounded bg-gold sm:mt-1" aria-hidden="true" />
            </div>
            <div class="sm:pt-1">
              <h3 class="text-h3">{t(`pricing.s${n}.t`)}</h3>
              <p class="mt-2 max-w-2xl text-muted">{t(`pricing.s${n}.d`)}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      <div class="rounded-lg border-l-2 border-gold bg-ivory px-5 py-4">
        <h3 class="font-display text-lg text-ink">{t('pricing.tier.t')}</h3>
        <p class="mt-1 text-sm text-muted">{t('pricing.tier.d')}</p>
      </div>
      <div class="rounded-lg border-l-2 border-gold bg-ivory px-5 py-4">
        <h3 class="font-display text-lg text-ink">{t('pricing.child.t')}</h3>
        <p class="mt-1 text-sm text-muted">{t('pricing.child.d')}</p>
      </div>
    </div>

    <p class="mt-8 rounded-lg border border-line bg-ivory px-5 py-4 text-sm text-ink">{t('pricing.confirm')}</p>
  </div>
</section>
