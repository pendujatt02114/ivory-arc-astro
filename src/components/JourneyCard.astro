---
import Picture from './Picture.astro';

interface Props {
  title: string;
  regionLabel: string;
  days: number;
  hero: string; // base path without extension
  heroAlt: string;
  summary: string;
  price: string; // pre-formatted, e.g. "₹32,000"
  fromLabel: string;
  perDayLabel: string;
  ctaLabel: string;
  href?: string;
}
const {
  title,
  regionLabel,
  days,
  hero,
  heroAlt,
  summary,
  price,
  fromLabel,
  perDayLabel,
  ctaLabel,
  href = '/plan',
} = Astro.props;

// Native dimensions per journey hero → responsive srcset with no 404s or upscaling.
const HERO_DIM: Record<string, [number, number]> = {
  '/assets/destinations/varanasi/varanasi-aarti': [1067, 1600],
  '/assets/photos/agra': [714, 1280],
  '/assets/photos/amritsar': [1280, 848],
  '/assets/photos/rishikesh': [1280, 720],
  '/assets/photos/shimla-train': [1280, 960],
  '/assets/thumbnails/jaisalmer': [720, 1280],
};
const [hw, hh] = HERO_DIM[hero] ?? [900, 600];
const heroWidths = [640, 960].filter((w) => w < hw);
---
<article class="flex flex-col overflow-hidden rounded-lg border border-line bg-ivory">
  <Picture
    base={hero}
    alt={heroAlt}
    width={hw}
    height={hh}
    widths={heroWidths}
    sizes="(min-width: 768px) 33vw, 100vw"
    class="block aspect-[3/2] w-full"
    imgClass="h-full w-full object-cover"
  />
  <div class="flex flex-1 flex-col p-6">
    <p class="text-xs font-medium uppercase tracking-[0.16em] text-teal-700">
      {regionLabel} · {days} days
    </p>
    <h3 class="mt-2 text-h3">{title}</h3>
    <p class="mt-2 text-sm text-muted">{summary}</p>
    <div class="mt-auto flex items-end justify-between gap-4 border-t border-line pt-4">
      <p class="text-sm text-muted">
        {fromLabel} <span class="font-display text-xl text-ink">{price}</span>
        {perDayLabel}
      </p>
      <a
        href={href}
        class="shrink-0 text-sm font-semibold text-teal underline underline-offset-4 hover:text-teal-700"
        data-cta
        data-cta-target="estimator"
        data-cta-location="journey_card"
        data-cta-label={ctaLabel}
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</article>
