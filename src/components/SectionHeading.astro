---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'center' | 'left';
  light?: boolean;
  as?: 'h1' | 'h2'; // semantic level — use h1 when this is the page's main title
}
const { eyebrow, title, intro, align = 'center', light = false, as = 'h2' } = Astro.props;
const wrap = align === 'center' ? 'mx-auto text-center' : 'text-left';
const Heading = as;
---
<div class:list={[wrap, 'max-w-2xl']}>
  {
    eyebrow && (
      <p
        class:list={[
          'text-xs font-medium uppercase tracking-[0.22em]',
          light ? 'text-gold' : 'text-teal-700',
        ]}
      >
        {eyebrow}
      </p>
    )
  }
  <Heading class:list={['text-h2', eyebrow ? 'mt-3' : '', light ? '!text-ivory' : '']}>{title}</Heading>
  {intro && <p class:list={['mt-4 text-lg', light ? 'text-ivory/80' : 'text-muted']}>{intro}</p>}
</div>
