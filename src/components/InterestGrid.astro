---
import SectionHeading from './SectionHeading.astro';
import ExperienceShowcase from './ExperienceShowcase.svelte';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const P = (s: string) => `/assets/photos/${s}`;
const T = (s: string) => `/assets/thumbnails/${s}`;
const V = '/assets/destinations/varanasi/varanasi-aarti';

// Photos cycle within each interest so the section never looks static. Captions
// describe the SUBJECT of each photograph — kept distinct from the Destinations grid.
const frames = {
  heritage: [
    { base: P('agra'), subject: 'Taj Mahal, Agra', line: 'Marble and morning light on the Yamuna', alt: 'The Taj Mahal at dawn' },
    { base: P('delhi'), subject: 'Red Fort, Delhi', line: 'The Mughal seat of power in red sandstone', alt: 'The Red Fort, Delhi' },
    { base: P('delhi-humayun'), subject: "Humayun's Tomb, Delhi", line: 'The garden tomb that inspired the Taj', alt: "Humayun's Tomb, Delhi" },
    { base: P('jaipur'), subject: 'Hawa Mahal, Jaipur', line: 'The pink palace of a thousand windows', alt: 'Hawa Mahal, Jaipur' },
    { base: T('jodhpur'), subject: 'Mehrangarh Fort, Jodhpur', line: 'Ramparts towering over the blue city', alt: 'Mehrangarh Fort, Jodhpur' },
    { base: T('bikaner'), subject: 'Junagarh Fort, Bikaner', line: 'Carved sandstone courts of the Rathores', alt: 'Junagarh Fort, Bikaner' },
    { base: T('jaisalmer'), subject: 'Jaisalmer Fort', line: 'A living fort in golden stone', alt: 'Jaisalmer Fort' },
  ],
  spiritual: [
    { base: P('amritsar'), subject: 'Golden Temple, Amritsar', line: 'Gold on still water, open to all', alt: 'The Golden Temple, Amritsar' },
    { base: V, subject: 'Ganga Aarti, Varanasi', line: 'Lamp-lit evening prayer on the ghats', alt: 'Ganga Aarti at Varanasi' },
    { base: P('mathura'), subject: 'Prem Mandir, Vrindavan', line: 'A marble temple to Krishna, lit at dusk', alt: 'Prem Mandir, Vrindavan' },
    { base: P('haridwar'), subject: 'Ganga Aarti, Haridwar', line: 'Lamps carried downstream at Har Ki Pauri', alt: 'Ganga Aarti at Haridwar' },
    { base: T('pushkar'), subject: 'Brahma Ghats, Pushkar', line: 'A sacred lake circled by temples', alt: 'Ghats at Pushkar' },
    { base: T('ayodhya'), subject: 'Ram Mandir, Ayodhya', line: 'The illuminated shrine on the Sarayu', alt: 'Ram Mandir, Ayodhya' },
  ],
  wildlife: [
    { base: P('corbett'), subject: 'Jim Corbett', line: 'A tiger on the move in the foothills', alt: 'A tiger at Jim Corbett' },
    { base: T('ranthambore'), subject: 'Ranthambore', line: 'Tiger country around a hilltop fort', alt: 'Tiger reserve at Ranthambore' },
  ],
  mountains: [
    { base: P('shimla-train'), subject: 'Kalka–Shimla Railway', line: 'The toy train through deodar forest', alt: 'The Kalka–Shimla toy train' },
    { base: P('shimla-track'), subject: 'Shimla hills', line: 'Pine ridges and a Himalayan sunset', alt: 'Sunset over the Shimla hills' },
    { base: T('khajjiar'), subject: 'Khajjiar', line: 'Meadows ringed by deodar — the “mini Switzerland”', alt: 'Alpine meadows at Khajjiar' },
    { base: T('solang-valley'), subject: 'Solang Valley', line: 'Snow and high air above Manali', alt: 'Solang Valley near Manali' },
    { base: P('rishikesh'), subject: 'Rishikesh foothills', line: 'The Ganga between forested hills', alt: 'The Ganga at Rishikesh' },
  ],
  pilgrimage: [
    { base: P('haridwar'), subject: 'Har Ki Pauri, Haridwar', line: 'The aarti where the Ganga meets the plains', alt: 'Har Ki Pauri, Haridwar' },
    { base: T('vaishno-devi'), subject: 'Vaishno Devi', line: 'The revered cave-shrine trek', alt: 'Pilgrimage trail to Vaishno Devi' },
    { base: P('amritsar'), subject: 'Golden Temple, Amritsar', line: "Sikhism's holiest pilgrimage", alt: 'The Golden Temple, Amritsar' },
    { base: P('varanasi-ghats'), subject: 'Ghats of Varanasi', line: 'Pilgrims and boats along the holy river', alt: 'The ghats of Varanasi' },
    { base: T('ayodhya'), subject: 'Ayodhya', line: 'A birthplace pilgrimage on the Sarayu', alt: 'Ayodhya' },
  ],
  luxury: [
    { base: T('udaipur'), subject: 'Lake Palace, Udaipur', line: 'Island palaces afloat on Pichola', alt: 'Lake palace, Udaipur' },
    { base: T('jaisalmer'), subject: 'Desert camps, Jaisalmer', line: 'Dunes, firelight and Thar stars', alt: 'Desert near Jaisalmer' },
    { base: T('jodhpur'), subject: 'Palace stays, Jodhpur', line: 'Heritage suites over the blue city', alt: 'Heritage stay, Jodhpur' },
    { base: P('jaipur'), subject: 'Palaces of Jaipur', line: 'Royal Rajasthan in pink and gold', alt: 'Palace architecture in Jaipur' },
  ],
} as const;

const order = ['heritage', 'spiritual', 'wildlife', 'mountains', 'pilgrimage', 'luxury'] as const;

const items = order.map((key) => ({
  key,
  label: t(`interest.${key}`),
  href: `/experiences/${key}`,
  frames: frames[key] as unknown as { base: string; subject: string; line: string; alt: string }[],
}));
---
<section id="experiences" class="container-ed scroll-mt-24 py-16 md:py-24">
  <SectionHeading eyebrow={t('interests.eyebrow')} title={t('interests.title')} />
  <ExperienceShowcase items={items} client:visible />
</section>
