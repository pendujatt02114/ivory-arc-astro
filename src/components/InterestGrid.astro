---
import SectionHeading from './SectionHeading.astro';
import Picture from './Picture.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const items = [
  { key: 'heritage', img: 'jodhpur', alt: 'The blue city of Jodhpur beneath Mehrangarh Fort' },
  { key: 'spiritual', img: 'ayodhya', alt: 'The Ram Mandir at Ayodhya, illuminated' },
  { key: 'wildlife', img: 'ranthambore', alt: 'A tiger in Ranthambore National Park' },
  { key: 'mountains', img: 'khajjiar', alt: 'Alpine meadows at Khajjiar, Himachal Pradesh' },
  { key: 'pilgrimage', img: 'vaishno-devi', alt: 'The temple-lined pilgrimage trail to Vaishno Devi' },
  { key: 'luxury', img: 'udaipur', alt: 'A lake palace in Udaipur at dusk' },
] as const;
---
<section id="experiences" class="container-ed scroll-mt-24 py-16 md:py-24">
  <SectionHeading eyebrow={t('interests.eyebrow')} title={t('interests.title')} />
  <ul class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-5">
    {
      items.map((it) => (
        <li>
          <a
            href={`/experiences/${it.key}`}
            class="group relative block overflow-hidden rounded-lg"
            data-cta
            data-cta-target="nav"
            data-cta-location="interest_grid"
            data-cta-label={t(`interest.${it.key}`)}
          >
            <Picture
              base={`/assets/thumbnails/${it.img}`}
              alt={it.alt}
              width={800}
              height={1000}
              sizes="(min-width: 768px) 33vw, 50vw"
              class="block aspect-[4/5] w-full"
              imgClass="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-teal-900/80 via-teal-900/10 to-transparent" />
            <h3 class="absolute inset-x-0 bottom-0 p-4 font-display text-xl !text-ivory">
              {t(`interest.${it.key}`)}
            </h3>
          </a>
        </li>
      ))
    }
  </ul>
</section>
