---
/*
  Minimal GDPR consent banner that drives Google Consent Mode v2.
  - Shows once on first visit; the decision is stored in the `ia_consent` cookie (180d).
  - Accept  → grants ad_storage / ad_user_data / ad_personalization / analytics_storage.
  - Decline → leaves them denied (the Consent Mode default set in BaseLayout).
  This is a scaffold. Swap in a certified CMP (Cookiebot, Osano, iubenda, CookieYes)
  if you need full IAB TCF v2.2 support — the gtag('consent','update', …) contract
  below is exactly what any CMP must call, so the rest of the stack is unaffected.
*/
---
<div
  id="ia-consent"
  hidden
  role="dialog"
  aria-live="polite"
  aria-label="Cookie consent"
  class="fixed inset-x-0 bottom-0 z-[70] border-t border-teal-700 bg-teal-900 text-ivory"
>
  <div class="container-ed flex flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm leading-relaxed text-ivory/90">
      We use cookies for analytics and to measure our advertising. You can accept or decline —
      see our <a href="/legal/privacy" class="underline underline-offset-2">Privacy Policy</a>.
    </p>
    <div class="flex shrink-0 gap-2">
      <button type="button" data-consent="decline"
        class="rounded-md border border-ivory/50 px-4 py-2 text-sm font-medium text-ivory">Decline</button>
      <button type="button" data-consent="accept"
        class="rounded-md bg-gold px-4 py-2 text-sm font-semibold text-ink">Accept</button>
    </div>
  </div>
</div>
<script is:inline>
  (function () {
    function getCookie(n) { var m = document.cookie.match(new RegExp('(?:^|; )' + n + '=([^;]*)')); return m ? decodeURIComponent(m[1]) : ''; }
    function setCookie(n, v) { document.cookie = n + '=' + encodeURIComponent(v) + '; path=/; max-age=' + (60 * 60 * 24 * 180) + '; samesite=lax'; }
    if (getCookie('ia_consent')) return; // already decided on a prior visit
    var el = document.getElementById('ia-consent');
    if (!el) return;
    el.hidden = false;
    function decide(grant) {
      setCookie('ia_consent', grant ? 'granted' : 'denied');
      if (typeof gtag === 'function') {
        gtag('consent', 'update', grant
          ? { ad_storage: 'granted', ad_user_data: 'granted', ad_personalization: 'granted', analytics_storage: 'granted' }
          : { ad_storage: 'denied',  ad_user_data: 'denied',  ad_personalization: 'denied',  analytics_storage: 'denied'  });
      }
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: grant ? 'consent_granted' : 'consent_denied' });
      el.hidden = true;
    }
    el.querySelector('[data-consent="accept"]').addEventListener('click', function () { decide(true); });
    el.querySelector('[data-consent="decline"]').addEventListener('click', function () { decide(false); });
  })();
</script>
