---
import SectionHeading from './SectionHeading.astro';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const points = [1, 2, 3, 4] as const;
---
<section id="why" class="container-ed scroll-mt-24 py-16 md:py-24">
  <SectionHeading eyebrow={t('why.eyebrow')} title={t('why.title')} />
  <dl class="mt-12 grid gap-x-10 gap-y-8 sm:grid-cols-2">
    {
      points.map((n) => (
        <div class="border-t border-line pt-5">
          <dt class="text-h3">{t(`why.p${n}.t`)}</dt>
          <dd class="mt-2 text-muted">{t(`why.p${n}.d`)}</dd>
        </div>
      ))
    }
  </dl>
</section>
