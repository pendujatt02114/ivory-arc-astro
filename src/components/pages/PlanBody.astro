---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PricingSteps from '../PricingSteps.astro';
import Estimator from '../Estimator.svelte';
import type { Lang } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;

const C: Record<string, { mt: string; md: string; eyebrow: string; h1: string; sub: string }> = {
  en: { mt: 'Plan your journey — Ivory Arc Travels', md: 'Shape a private North India journey and share it with IVY for an honest, transparent quote in INR.', eyebrow: 'Plan your journey', h1: 'Shape your journey, then hand it to IVY.', sub: "Tell us the essentials and we'll pass the brief to IVY, who builds your itinerary and a transparent quote in INR — no fixed packages, hotels at actual cost plus a clear 10% coordination fee." },
  es: { mt: 'Planifica tu viaje — Ivory Arc Travels', md: 'Diseña un viaje privado por el norte de la India y compártelo con IVY para un presupuesto honesto y transparente en INR.', eyebrow: 'Planifica tu viaje', h1: 'Diseña tu viaje y pásalo a IVY.', sub: 'Cuéntanos lo esencial y pasaremos la solicitud a IVY, que crea tu itinerario y un presupuesto transparente en INR: sin paquetes fijos, hoteles a coste real más una comisión de coordinación clara del 10%.' },
  de: { mt: 'Reise planen — Ivory Arc Travels', md: 'Gestalten Sie eine private Nordindien-Reise und übergeben Sie sie IVY für ein ehrliches, transparentes Angebot in INR.', eyebrow: 'Reise planen', h1: 'Gestalten Sie Ihre Reise und übergeben Sie sie IVY.', sub: 'Nennen Sie uns das Wesentliche, und wir übergeben den Auftrag an IVY, die Ihre Route und ein transparentes Angebot in INR erstellt — keine Pauschalpakete, Hotels zum tatsächlichen Preis plus klare 10% Koordinationsgebühr.' },
  fr: { mt: 'Planifiez votre voyage — Ivory Arc Travels', md: "Composez un voyage privé dans le nord de l'Inde et confiez-le à IVY pour un devis honnête et transparent en INR.", eyebrow: 'Planifiez votre voyage', h1: 'Composez votre voyage, puis confiez-le à IVY.', sub: "Donnez-nous l'essentiel et nous transmettrons la demande à IVY, qui crée votre itinéraire et un devis transparent en INR — pas de forfaits figés, hôtels au coût réel plus des frais de coordination clairs de 10%." },
  it: { mt: 'Pianifica il tuo viaggio — Ivory Arc Travels', md: "Componi un viaggio privato nell'India del Nord e affidalo a IVY per un preventivo onesto e trasparente in INR.", eyebrow: 'Pianifica il tuo viaggio', h1: 'Componi il tuo viaggio e affidalo a IVY.', sub: "Dicci l'essenziale e passeremo la richiesta a IVY, che crea il tuo itinerario e un preventivo trasparente in INR — nessun pacchetto fisso, hotel al costo reale più una chiara commissione di coordinamento del 10%." },
  ru: { mt: 'Планирование путешествия — Ivory Arc Travels', md: 'Составьте частное путешествие по Северной Индии и передайте его IVY для честной прозрачной сметы в INR.', eyebrow: 'Планирование путешествия', h1: 'Составьте маршрут и передайте его IVY.', sub: 'Расскажите главное, и мы передадим запрос IVY, которая составит ваш маршрут и прозрачную смету в INR — без фиксированных пакетов, отели по фактической стоимости плюс понятная координационная комиссия 10%.' },
};
const c = C[lang] ?? C.en;
const canonical = lang === 'en' ? '/plan' : `/${lang}/plan`;
---
<BaseLayout title={c.mt} description={c.md} lang={lang} canonical={canonical} hreflangPath="/plan" barEmphasis="ivy">
  <section class="container-ed py-14 md:py-20">
    <div class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.24em] text-teal-700">{c.eyebrow}</p>
      <h1 class="mt-4 text-display">{c.h1}</h1>
      <p class="mt-5 text-lg text-muted">{c.sub}</p>
    </div>
    <div class="mt-10"><Estimator lang={lang} client:idle /></div>
  </section>
  <PricingSteps lang={lang} />
</BaseLayout>
