---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../SectionHeading.astro';
import CTAButton from '../CTAButton.astro';
import WhatsAppLink from '../WhatsAppLink.astro';
import { SITE } from '../../consts';
import type { Lang } from '../../i18n/ui';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;

const C: Record<string, any> = {
  en: {
    mt: 'About — Ivory Arc Travels', md: 'Ivory Arc Travels is a women-owned, family-run private travel company founded in 2019 by Sonu Tomar — built on firsthand knowledge of every road, temple and city across North India.',
    eyebrow: 'About', h1: 'Founded on experience, run with care.',
    intro: 'Ivory Arc Travels is a women-owned, family-run private travel company — built on firsthand knowledge of every road, temple and city we send you to. Honest. Unhurried. Yours.',
    storyH: 'Our story',
    p1: 'Ivory Arc Travels was founded in 2019 by <strong class="text-ink">Sonu Tomar</strong>, a passionate traveller who believes exceptional journeys are built on personal experience, meticulous planning and genuine care for every guest. What began as a family-led venture now combines decades of expertise from across the travel ecosystem.',
    p2: 'Sonu\u2019s father, an <strong class="text-ink">Army veteran</strong>, has been involved in travel operations since 2016 — bringing discipline, reliability and a service-first approach to every itinerary. Her husband contributes over a decade of experience with leading travel management companies, online travel agencies, airlines and hospitality brands.',
    p3: 'What truly sets us apart is <strong class="text-ink">firsthand destination knowledge</strong>. Sonu has personally visited every destination in our curated journeys — many of them several times over. That lets us craft experiences that are practical, authentic and thoughtfully designed: every route, stay and activity chosen from real-world experience, not online research alone.',
    philoH: 'Enriching, stress-free, transparent.',
    ph1: 'We specialise in private, thoughtfully curated experiences that prioritise quality over volume. Rather than selling standard packages, we start by understanding your interests, travel style and expectations — then build a journey that feels personal and meaningful. Whether you\u2019re a solo traveller, a couple, a family or a small private group, we plan around secure stays, trusted local partners, realistic pacing and seamless logistics.',
    ph2: 'Our philosophy is simple: travel should be enriching, stress-free and transparent. It\u2019s why we hold ourselves to three promises on every trip.',
    promises: [
      { t: 'No commission stops', d: 'Never any commission-driven shopping detours — your time on the road is spent on what you came for.' },
      { t: 'All of North India', d: 'From Agra and the Taj to the Golden Temple, the Ganges and the Himalaya — one team across the whole region.' },
      { t: 'Private, always', d: 'Your own vehicle, guide and pace — never a fixed group departure or a shared coach.' },
    ],
    glanceH: 'At a glance',
    g: [['Founded', '2019, by Sonu Tomar — women-owned & family-run'], ['Where we\u2019re based', `${SITE.city}, ${SITE.region}`], ['Where we travel', `${SITE.destinationCount} destinations across North India`], ['How we travel', 'Private journeys only — your own vehicle, driver and guides'], ['Registration', `Registered Indian tour operator · GST ${SITE.gst} · ${SITE.msme}`]],
    estimate: 'Get an estimate',
  },
  es: {
    mt: 'Quiénes somos — Ivory Arc Travels', md: 'Ivory Arc Travels es una empresa de viajes privada, dirigida por mujeres y de gestión familiar, fundada en 2019 por Sonu Tomar, basada en el conocimiento de primera mano de cada lugar del norte de la India.',
    eyebrow: 'Quiénes somos', h1: 'Fundada en la experiencia, gestionada con cuidado.',
    intro: 'Ivory Arc Travels es una empresa de viajes privada, dirigida por mujeres y de gestión familiar, construida sobre el conocimiento de primera mano de cada carretera, templo y ciudad a los que te enviamos. Honesta. Sin prisas. Tuya.',
    storyH: 'Nuestra historia',
    p1: 'Ivory Arc Travels fue fundada en 2019 por <strong class="text-ink">Sonu Tomar</strong>, una viajera apasionada que cree que los viajes excepcionales se construyen sobre la experiencia personal, una planificación meticulosa y un cuidado genuino por cada huésped. Lo que comenzó como un proyecto familiar combina hoy décadas de experiencia de todo el sector turístico.',
    p2: 'El padre de Sonu, <strong class="text-ink">veterano del Ejército</strong>, participa en operaciones de viajes desde 2016, aportando disciplina, fiabilidad y un enfoque centrado en el servicio. Su esposo aporta más de una década de experiencia con destacadas empresas de gestión de viajes, agencias en línea, aerolíneas y marcas de hostelería.',
    p3: 'Lo que de verdad nos distingue es el <strong class="text-ink">conocimiento de primera mano</strong>. Sonu ha visitado personalmente cada destino de nuestros viajes, muchos de ellos varias veces. Eso nos permite crear experiencias prácticas, auténticas y bien pensadas: cada ruta, alojamiento y actividad elegidos desde la experiencia real, no solo desde la investigación en línea.',
    philoH: 'Enriquecedor, sin estrés, transparente.',
    ph1: 'Nos especializamos en experiencias privadas y cuidadosamente diseñadas que priorizan la calidad sobre la cantidad. En lugar de vender paquetes estándar, empezamos por entender tus intereses, tu estilo de viaje y tus expectativas, y luego creamos un viaje personal y significativo. Ya seas un viajero solo, una pareja, una familia o un pequeño grupo privado, planificamos con alojamientos seguros, socios locales de confianza, ritmos realistas y una logística impecable.',
    ph2: 'Nuestra filosofía es sencilla: viajar debe ser enriquecedor, sin estrés y transparente. Por eso nos comprometemos a tres promesas en cada viaje.',
    promises: [
      { t: 'Sin paradas por comisión', d: 'Nunca desvíos de compras por comisión: tu tiempo se dedica a lo que viniste a ver.' },
      { t: 'Todo el norte de la India', d: 'Desde Agra y el Taj hasta el Templo Dorado, el Ganges y el Himalaya, un solo equipo en toda la región.' },
      { t: 'Privado, siempre', d: 'Tu propio vehículo, guía y ritmo, nunca una salida en grupo ni un autobús compartido.' },
    ],
    glanceH: 'De un vistazo',
    g: [['Fundada', '2019, por Sonu Tomar — dirigida por mujeres y familiar'], ['Dónde estamos', `${SITE.city}, ${SITE.region}`], ['Dónde viajamos', `${SITE.destinationCount} destinos por el norte de la India`], ['Cómo viajamos', 'Solo viajes privados: tu propio vehículo, conductor y guías'], ['Registro', `Operador turístico indio registrado · GST ${SITE.gst} · ${SITE.msme}`]],
    estimate: 'Obtener un presupuesto',
  },
  de: {
    mt: 'Über uns — Ivory Arc Travels', md: 'Ivory Arc Travels ist ein von Frauen geführtes, familiengeführtes privates Reiseunternehmen, 2019 von Sonu Tomar gegründet — auf erster Hand erworbenem Wissen über ganz Nordindien.',
    eyebrow: 'Über uns', h1: 'Auf Erfahrung gegründet, mit Sorgfalt geführt.',
    intro: 'Ivory Arc Travels ist ein von Frauen geführtes, familiengeführtes privates Reiseunternehmen — gegründet auf erster Hand erworbenem Wissen über jede Straße, jeden Tempel und jede Stadt, zu der wir Sie schicken. Ehrlich. Ohne Hast. Ihre.',
    storyH: 'Unsere Geschichte',
    p1: 'Ivory Arc Travels wurde 2019 von <strong class="text-ink">Sonu Tomar</strong> gegründet, einer leidenschaftlichen Reisenden, die überzeugt ist, dass außergewöhnliche Reisen auf persönlicher Erfahrung, sorgfältiger Planung und echter Fürsorge für jeden Gast beruhen. Was als familiengeführtes Vorhaben begann, vereint heute jahrzehntelange Erfahrung aus der gesamten Reisebranche.',
    p2: 'Sonus Vater, ein <strong class="text-ink">Armeeveteran</strong>, ist seit 2016 im Reisebetrieb tätig und bringt Disziplin, Verlässlichkeit und einen serviceorientierten Ansatz ein. Ihr Mann steuert über ein Jahrzehnt Erfahrung bei führenden Reisemanagement-Unternehmen, Online-Reisebüros, Fluggesellschaften und Hotelmarken bei.',
    p3: 'Was uns wirklich auszeichnet, ist <strong class="text-ink">Wissen aus erster Hand</strong>. Sonu hat jedes Reiseziel unserer Reisen persönlich besucht — viele davon mehrfach. So gestalten wir Erlebnisse, die praktisch, authentisch und durchdacht sind: jede Route, Unterkunft und Aktivität aus echter Erfahrung gewählt, nicht nur aus Online-Recherche.',
    philoH: 'Bereichernd, stressfrei, transparent.',
    ph1: 'Wir sind auf private, sorgfältig kuratierte Erlebnisse spezialisiert, die Qualität vor Menge stellen. Statt Standardpakete zu verkaufen, verstehen wir zuerst Ihre Interessen, Ihren Reisestil und Ihre Erwartungen — und gestalten dann eine persönliche, bedeutungsvolle Reise. Ob Alleinreisende, Paar, Familie oder kleine private Gruppe: Wir planen mit sicheren Unterkünften, vertrauenswürdigen lokalen Partnern, realistischem Tempo und reibungsloser Logistik.',
    ph2: 'Unsere Philosophie ist einfach: Reisen soll bereichernd, stressfrei und transparent sein. Deshalb halten wir uns bei jeder Reise an drei Versprechen.',
    promises: [
      { t: 'Keine Provisionsstopps', d: 'Niemals provisionsgetriebene Einkaufsumwege — Ihre Zeit gilt dem, wofür Sie gekommen sind.' },
      { t: 'Ganz Nordindien', d: 'Von Agra und dem Taj bis zum Goldenen Tempel, dem Ganges und dem Himalaya — ein Team in der ganzen Region.' },
      { t: 'Immer privat', d: 'Ihr eigenes Fahrzeug, Guide und Tempo — nie eine Gruppenabreise oder ein gemeinsamer Bus.' },
    ],
    glanceH: 'Auf einen Blick',
    g: [['Gegründet', '2019, von Sonu Tomar — von Frauen geführt & familiengeführt'], ['Standort', `${SITE.city}, ${SITE.region}`], ['Reisegebiet', `${SITE.destinationCount} Reiseziele in Nordindien`], ['Reiseart', 'Nur private Reisen — Ihr eigenes Fahrzeug, Fahrer und Guides'], ['Registrierung', `Registrierter indischer Reiseveranstalter · GST ${SITE.gst} · ${SITE.msme}`]],
    estimate: 'Angebot erhalten',
  },
  fr: {
    mt: 'À propos — Ivory Arc Travels', md: "Ivory Arc Travels est une agence de voyage privée, dirigée par des femmes et familiale, fondée en 2019 par Sonu Tomar — fondée sur une connaissance de première main de tout le nord de l'Inde.",
    eyebrow: 'À propos', h1: "Fondée sur l'expérience, gérée avec soin.",
    intro: "Ivory Arc Travels est une agence de voyage privée, dirigée par des femmes et familiale — fondée sur une connaissance de première main de chaque route, temple et ville où nous vous envoyons. Honnête. Sans hâte. La vôtre.",
    storyH: 'Notre histoire',
    p1: "Ivory Arc Travels a été fondée en 2019 par <strong class=\"text-ink\">Sonu Tomar</strong>, une voyageuse passionnée convaincue que les voyages d'exception reposent sur l'expérience personnelle, une planification méticuleuse et une attention sincère à chaque client. Ce qui a commencé comme une aventure familiale réunit aujourd'hui des décennies d'expertise de tout le secteur du voyage.",
    p2: "Le père de Sonu, <strong class=\"text-ink\">vétéran de l'armée</strong>, est impliqué dans les opérations de voyage depuis 2016, apportant discipline, fiabilité et sens du service. Son mari apporte plus de dix ans d'expérience auprès de grandes sociétés de gestion de voyages, d'agences en ligne, de compagnies aériennes et de marques hôtelières.",
    p3: "Ce qui nous distingue vraiment, c'est la <strong class=\"text-ink\">connaissance de première main</strong>. Sonu a personnellement visité chaque destination de nos voyages, beaucoup plusieurs fois. Cela nous permet de concevoir des expériences pratiques, authentiques et réfléchies : chaque itinéraire, hébergement et activité choisi à partir d'une expérience réelle, pas seulement de recherches en ligne.",
    philoH: 'Enrichissant, sans stress, transparent.',
    ph1: "Nous scommes spécialisés dans des expériences privées et soigneusement conçues qui privilégient la qualité à la quantité. Plutôt que de vendre des forfaits standards, nous commençons par comprendre vos centres d'intérêt, votre style de voyage et vos attentes, puis nous créons un voyage personnel et porteur de sens. Que vous voyagiez seul, en couple, en famille ou en petit groupe privé, nous planifions avec des hébergements sûrs, des partenaires locaux de confiance, un rythme réaliste et une logistique sans faille.",
    ph2: 'Notre philosophie est simple : voyager doit être enrichissant, sans stress et transparent. C\u2019est pourquoi nous tenons trois promesses à chaque voyage.',
    promises: [
      { t: 'Aucun arrêt de commission', d: 'Jamais de détours shopping pour commission — votre temps est consacré à ce pour quoi vous êtes venu.' },
      { t: "Tout le nord de l'Inde", d: 'D\u2019Agra et du Taj au Temple d\u2019Or, au Gange et à l\u2019Himalaya — une seule équipe sur toute la région.' },
      { t: 'Privé, toujours', d: 'Votre propre véhicule, guide et rythme — jamais de départ en groupe ni de car partagé.' },
    ],
    glanceH: 'En un coup d\u2019\u0153il',
    g: [['Fondée', '2019, par Sonu Tomar — dirigée par des femmes et familiale'], ['Où nous sommes', `${SITE.city}, ${SITE.region}`], ['Où nous voyageons', `${SITE.destinationCount} destinations dans le nord de l'Inde`], ['Comment nous voyageons', 'Voyages privés uniquement — votre propre véhicule, chauffeur et guides'], ['Enregistrement', `Voyagiste indien enregistré · GST ${SITE.gst} · ${SITE.msme}`]],
    estimate: 'Obtenir un devis',
  },
  it: {
    mt: 'Chi siamo — Ivory Arc Travels', md: "Ivory Arc Travels è un'agenzia di viaggi privata, gestita da donne e a conduzione familiare, fondata nel 2019 da Sonu Tomar — basata sulla conoscenza diretta di tutta l'India del Nord.",
    eyebrow: 'Chi siamo', h1: "Fondata sull'esperienza, gestita con cura.",
    intro: "Ivory Arc Travels è un'agenzia di viaggi privata, gestita da donne e a conduzione familiare — fondata sulla conoscenza diretta di ogni strada, tempio e città in cui ti mandiamo. Onesta. Senza fretta. Tua.",
    storyH: 'La nostra storia',
    p1: 'Ivory Arc Travels è stata fondata nel 2019 da <strong class="text-ink">Sonu Tomar</strong>, una viaggiatrice appassionata convinta che i viaggi eccezionali nascano da esperienza personale, pianificazione meticolosa e cura autentica per ogni ospite. Ciò che è nato come un\u2019impresa familiare riunisce oggi decenni di competenza da tutto il settore dei viaggi.',
    p2: 'Il padre di Sonu, <strong class="text-ink">veterano dell\u2019esercito</strong>, si occupa di operazioni di viaggio dal 2016, portando disciplina, affidabilità e un approccio orientato al servizio. Suo marito apporta oltre un decennio di esperienza con importanti società di gestione viaggi, agenzie online, compagnie aeree e marchi dell\u2019ospitalità.',
    p3: 'Ciò che ci distingue davvero è la <strong class="text-ink">conoscenza diretta</strong>. Sonu ha visitato personalmente ogni destinazione dei nostri viaggi, molte più volte. Questo ci permette di creare esperienze pratiche, autentiche e ben studiate: ogni itinerario, soggiorno e attività scelti dall\u2019esperienza reale, non solo da ricerche online.',
    philoH: 'Arricchente, senza stress, trasparente.',
    ph1: 'Siamo specializzati in esperienze private e curate che privilegiano la qualità sulla quantità. Invece di vendere pacchetti standard, partiamo dalla comprensione dei tuoi interessi, del tuo stile di viaggio e delle tue aspettative, poi creiamo un viaggio personale e significativo. Che tu sia un viaggiatore singolo, una coppia, una famiglia o un piccolo gruppo privato, pianifichiamo con soggiorni sicuri, partner locali fidati, ritmi realistici e una logistica impeccabile.',
    ph2: 'La nostra filosofia è semplice: viaggiare deve essere arricchente, senza stress e trasparente. Per questo manteniamo tre promesse a ogni viaggio.',
    promises: [
      { t: 'Nessuna sosta a commissione', d: 'Mai deviazioni shopping a commissione: il tuo tempo è dedicato a ciò per cui sei venuto.' },
      { t: "Tutta l'India del Nord", d: 'Da Agra e il Taj al Tempio d\u2019Oro, al Gange e all\u2019Himalaya — un solo team in tutta la regione.' },
      { t: 'Privato, sempre', d: 'Il tuo veicolo, guida e ritmo — mai una partenza di gruppo o un pullman condiviso.' },
    ],
    glanceH: 'In sintesi',
    g: [['Fondata', '2019, da Sonu Tomar — gestita da donne e familiare'], ['Dove siamo', `${SITE.city}, ${SITE.region}`], ['Dove viaggiamo', `${SITE.destinationCount} destinazioni nell'India del Nord`], ['Come viaggiamo', 'Solo viaggi privati — il tuo veicolo, autista e guide'], ['Registrazione', `Operatore turistico indiano registrato · GST ${SITE.gst} · ${SITE.msme}`]],
    estimate: 'Richiedi un preventivo',
  },
  ru: {
    mt: 'О нас — Ivory Arc Travels', md: 'Ivory Arc Travels — частная туристическая компания, управляемая женщинами и семьёй, основанная в 2019 году Сону Томар на основе личного знания всей Северной Индии.',
    eyebrow: 'О нас', h1: 'Основано на опыте, ведётся с заботой.',
    intro: 'Ivory Arc Travels — частная туристическая компания, управляемая женщинами и семьёй, построенная на личном знании каждой дороги, храма и города, куда мы вас отправляем. Честно. Неспешно. Для вас.',
    storyH: 'Наша история',
    p1: 'Ivory Arc Travels основана в 2019 году <strong class="text-ink">Сону Томар</strong>, увлечённой путешественницей, убеждённой, что исключительные поездки строятся на личном опыте, тщательном планировании и искренней заботе о каждом госте. То, что началось как семейное дело, сегодня объединяет десятилетия опыта со всей сферы путешествий.',
    p2: 'Отец Сону, <strong class="text-ink">ветеран армии</strong>, занимается организацией путешествий с 2016 года, привнося дисциплину, надёжность и сервис прежде всего. Её муж добавляет более десяти лет опыта работы с ведущими компаниями по управлению поездками, онлайн-агентствами, авиакомпаниями и гостиничными брендами.',
    p3: 'Что действительно отличает нас — это <strong class="text-ink">личное знание направлений</strong>. Сону лично побывала в каждом направлении наших маршрутов, многие — несколько раз. Это позволяет создавать практичные, подлинные и продуманные впечатления: каждый маршрут, проживание и активность выбраны из реального опыта, а не только из онлайн-поиска.',
    philoH: 'Обогащающе, без стресса, прозрачно.',
    ph1: 'Мы специализируемся на частных, тщательно продуманных впечатлениях, где качество важнее количества. Вместо стандартных пакетов мы начинаем с понимания ваших интересов, стиля путешествий и ожиданий, а затем создаём личное и значимое путешествие. Будь вы одиночный путешественник, пара, семья или небольшая частная группа, мы планируем безопасное проживание, надёжных местных партнёров, реалистичный темп и безупречную логистику.',
    ph2: 'Наша философия проста: путешествие должно обогащать, быть без стресса и прозрачным. Поэтому в каждой поездке мы держим три обещания.',
    promises: [
      { t: 'Без остановок ради комиссии', d: 'Никаких торговых заездов ради комиссии — ваше время посвящено тому, ради чего вы приехали.' },
      { t: 'Вся Северная Индия', d: 'От Агры и Тадж-Махала до Золотого храма, Ганга и Гималаев — одна команда по всему региону.' },
      { t: 'Всегда приватно', d: 'Ваш собственный транспорт, гид и темп — никаких групповых выездов или общих автобусов.' },
    ],
    glanceH: 'Кратко',
    g: [['Основано', '2019, Сону Томар — управляется женщинами и семьёй'], ['Где мы', `${SITE.city}, ${SITE.region}`], ['Куда ездим', `${SITE.destinationCount} направлений по Северной Индии`], ['Как путешествуем', 'Только частные поездки — ваш транспорт, водитель и гиды'], ['Регистрация', `Зарегистрированный индийский туроператор · GST ${SITE.gst} · ${SITE.msme}`]],
    estimate: 'Получить смету',
  },
};
const c = C[lang] ?? C.en;
const canonical = lang === 'en' ? '/about' : `/${lang}/about`;
---
<BaseLayout title={c.mt} description={c.md} lang={lang} canonical={canonical} hreflangPath="/about">
  <section class="container-ed py-16 md:py-24">
    <SectionHeading as="h1" eyebrow={c.eyebrow} title={c.h1} intro={c.intro} align="left" />

    <div class="mt-10 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <div>
        <h2 class="text-h3">{c.storyH}</h2>
        <div class="mt-4 space-y-5 text-lg text-muted">
          <p set:html={c.p1} />
          <p set:html={c.p2} />
          <p set:html={c.p3} />
        </div>
      </div>

      <aside class="rounded-lg border border-line bg-cream p-6 lg:self-start">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">{c.glanceH}</h2>
        <dl class="mt-4 space-y-3 text-sm">
          {c.g.map((row: string[]) => (<div><dt class="text-muted">{row[0]}</dt><dd class="text-ink">{row[1]}</dd></div>))}
        </dl>
      </aside>
    </div>

    <div class="mt-16">
      <h2 class="text-h3">{c.philoH}</h2>
      <div class="mt-4 max-w-3xl space-y-5 text-lg text-muted">
        <p>{c.ph1}</p>
        <p>{c.ph2}</p>
      </div>
      <dl class="mt-8 grid gap-4 sm:grid-cols-3">
        {c.promises.map((p: any) => (
          <div class="rounded-lg border-l-2 border-gold bg-cream px-5 py-4">
            <dt class="font-display text-lg text-ink">{p.t}</dt>
            <dd class="mt-1 text-sm text-muted">{p.d}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class="mt-14 flex flex-col items-start gap-3 sm:flex-row">
      <WhatsAppLink variant="primary" location="about_footer" />
      <CTAButton href={lang === 'en' ? '/plan' : `/${lang}/plan`} variant="secondary" label={c.estimate} target="estimator" location="about_footer" />
    </div>
  </section>
</BaseLayout>
