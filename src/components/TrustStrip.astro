---
import { SITE } from '../consts';
import type { Lang } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;

// Text-only credentials strip beneath the hero — no logos by design. Localised inline.
type T = { eyebrow: string; c1: string; c2: string; c3: string; sub: string };
const STR: Record<string, T> = {
  en: { eyebrow: 'Registered & accredited', c1: 'GST Registered', c2: 'MSME Certified', c3: 'Govt of India Approved', sub: `Registered Indian tour operator · GST ${SITE.gst}` },
  es: { eyebrow: 'Registrada y acreditada', c1: 'GST registrada', c2: 'MSME certificada', c3: 'Aprobada por el Gobierno de la India', sub: `Operador turístico indio registrado · GST ${SITE.gst}` },
  de: { eyebrow: 'Registriert & akkreditiert', c1: 'GST-registriert', c2: 'MSME-zertifiziert', c3: 'Von der indischen Regierung anerkannt', sub: `Registrierter indischer Reiseveranstalter · GST ${SITE.gst}` },
  fr: { eyebrow: 'Enregistrée et accréditée', c1: 'Immatriculée à la GST', c2: 'Certifiée MSME', c3: 'Agréée par le gouvernement indien', sub: `Voyagiste indien agréé · GST ${SITE.gst}` },
  it: { eyebrow: 'Registrata e accreditata', c1: 'Registrata GST', c2: 'Certificata MSME', c3: 'Approvata dal Governo indiano', sub: `Tour operator indiano registrato · GST ${SITE.gst}` },
  ru: { eyebrow: 'Зарегистрирована и аккредитована', c1: 'Зарегистрирована в GST', c2: 'Сертификат MSME', c3: 'Одобрено Правительством Индии', sub: `Зарегистрированный индийский туроператор · GST ${SITE.gst}` },
};
const t = STR[lang] ?? STR.en;
const creds = [t.c1, t.c2, t.c3];
---
<section class="border-y border-line bg-cream" aria-label={t.eyebrow}>
  <div class="container-ed py-6 md:py-7">
    <p class="text-center text-xs font-medium uppercase tracking-[0.22em] text-teal-700">{t.eyebrow}</p>
    <ul class="mt-4 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 sm:gap-x-12 md:gap-x-14">
      {
        creds.map((c) => (
          <li class="flex items-center gap-2">
            <svg class="size-4 shrink-0 text-gold" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 10.5l3.5 3.5L16 5.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="font-display text-base text-ink md:text-lg">{c}</span>
          </li>
        ))
      }
    </ul>
    <p class="mt-4 text-center text-xs text-muted">{t.sub}</p>
  </div>
</section>
